@* TaskManager.Client/Pages/User/MyTasks.razor *@
@page "/user/tasks"
@attribute [Authorize(Roles = "User")]
@inject IApiService ApiService
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>My Tasks</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    <AppPageHeader Title="My Tasks" Subtitle="View and manage your assigned tasks" />

    <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="5">
                <MudSelect T="string" Value="filterStatus" ValueChanged="OnStatusFilterChanged" Label="Status" Variant="Variant.Outlined" Clearable="true">
                    <MudSelectItem Value="@("Assigned")">Assigned</MudSelectItem>
                    <MudSelectItem Value="@("InProgress")">In Progress</MudSelectItem>
                    <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                    <MudSelectItem Value="@("Tested")">Tested</MudSelectItem>
                    <MudSelectItem Value="@("Closed")">Closed</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="5">
                <MudSelect T="string" Value="filterPriority" ValueChanged="OnPriorityFilterChanged" Label="Priority" Variant="Variant.Outlined" Clearable="true">
                    <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                    <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                    <MudSelectItem Value="@("High")">High</MudSelectItem>
                    <MudSelectItem Value="@("Critical")">Critical</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudButton Variant="Variant.Outlined" FullWidth="true" OnClick="ClearFilters">Clear</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (isLoading)
    {
        <AppLoading Message="Loading tasks..." />
    }
    else if (!filteredTasks.Any())
    {
        <AppEmptyState Title="No Tasks Found" Description="You don't have any tasks matching the selected filters.">
            <Actions>
                <MudButton Variant="Variant.Outlined" OnClick="ClearFilters">Clear Filters</MudButton>
            </Actions>
        </AppEmptyState>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var task in filteredTasks)
            {
                var overdue = IsTaskOverdue(task);
                var progress = task.EstimatedHours.HasValue && task.EstimatedHours.Value > 0
                    ? Math.Min((double)task.ActualHours / (double)task.EstimatedHours.Value * 100, 100)
                    : 0;

                <MudItem xs="12" sm="6" lg="4">
                    <MudPaper Class="@($"glass-card pa-4 h-100{(overdue ? " task-card-overdue" : "")}")" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)">@task.Priority</MudChip>
                            <TaskStatusChip Status="@task.Status" />
                        </MudStack>

                        <MudText Typo="Typo.h6" Class="mb-1">@task.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                            Project: @task.ProjectName
                        </MudText>

                        @if (!string.IsNullOrEmpty(task.Description))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                @(task.Description.Length > 100 ? task.Description[..100] + "..." : task.Description)
                            </MudText>
                        }

                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Time Logged</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @task.ActualHours / @(task.EstimatedHours?.ToString() ?? "-") hrs
                            </MudText>
                        </MudStack>
                        @if (task.EstimatedHours.HasValue && task.EstimatedHours.Value > 0)
                        {
                            <MudProgressLinear Value="@progress"
                                               Color="@(progress > 100 ? Color.Error : Color.Primary)"
                                               Class="mb-3 rounded" />
                        }

                        @if (task.DueDate.HasValue)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
                                <MudText Typo="Typo.body2" Color="@(overdue ? Color.Error : Color.Default)">
                                    <strong>Due:</strong> @task.DueDate.Value.ToString("MMM dd, yyyy")
                                </MudText>
                                @if (overdue)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Overdue</MudChip>
                                }
                            </MudStack>
                        }

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Class="mt-auto"
                                   OnClick="@(() => ViewTaskDetails(task.Id!.Value))">
                            View Details
                        </MudButton>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<style>
    .task-card-overdue {
        border-color: var(--mud-palette-error) !important;
    }
</style>

@code {
    private List<TaskDto> tasks = new();
    private List<TaskDto> filteredTasks = new();
    private bool isLoading = true;
    private string? filterStatus = null;
    private string? filterPriority = null;

    protected override async Task OnInitializedAsync() => await LoadTasks();

    private async Task LoadTasks()
    {
        isLoading = true;
        try
        {
            tasks = await ApiService.GetTasksAsync() ?? new();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tasks: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        filteredTasks = tasks;

        if (!string.IsNullOrEmpty(filterStatus))
            filteredTasks = filteredTasks.Where(t => t.Status == filterStatus).ToList();

        if (!string.IsNullOrEmpty(filterPriority))
            filteredTasks = filteredTasks.Where(t => t.Priority == filterPriority).ToList();

        filteredTasks = filteredTasks
            .OrderByDescending(t => IsTaskOverdue(t))
            .ThenBy(t => t.DueDate ?? DateTime.MaxValue)
            .ThenByDescending(t => GetPriorityWeight(t.Priority))
            .ToList();
    }

    private void OnStatusFilterChanged(string? value)
    {
        filterStatus = value;
        ApplyFilters();
    }

    private void OnPriorityFilterChanged(string? value)
    {
        filterPriority = value;
        ApplyFilters();
    }

    private void ClearFilters()
    {
        filterStatus = null;
        filterPriority = null;
        ApplyFilters();
    }

    private void ViewTaskDetails(int taskId) => Navigation.NavigateTo($"/user/task/{taskId}");

    private static bool IsTaskOverdue(TaskDto task) =>
        task.DueDate.HasValue &&
        task.DueDate.Value < DateTime.Today &&
        task.Status is not ("Completed" or "Tested" or "Closed");

    private static int GetPriorityWeight(string priority) => priority switch
    {
        "Critical" => 4,
        "High" => 3,
        "Medium" => 2,
        "Low" => 1,
        _ => 0
    };

    private static Color GetPriorityColor(string priority) => priority switch
    {
        "Low" => Color.Success,
        "Medium" => Color.Info,
        "High" => Color.Warning,
        "Critical" => Color.Error,
        _ => Color.Default
    };
}
