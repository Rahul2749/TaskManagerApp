@* TaskManager.Client/Pages/User/TaskDetails.razor *@
@page "/user/task/{TaskId:int}"
@attribute [Authorize(Roles = "User")]
@inject IApiService ApiService
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Task Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    <MudButton Variant="Variant.Text"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="GoBack"
               Class="mb-4">
        Back to My Tasks
    </MudButton>

    @if (isLoading)
    {
        <AppLoading Message="Loading task details..." />
    }
    else if (task != null)
    {
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => successMessage = string.Empty)">
                @successMessage
            </MudAlert>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => errorMessage = string.Empty)">
                @errorMessage
            </MudAlert>
        }

        <MudGrid Spacing="4">
            <MudItem xs="12" md="8">
                <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="flex-wrap gap-2">
                        <MudText Typo="Typo.h4">@task.Title</MudText>
                        <MudStack Row="true" Spacing="1" Class="flex-wrap">
                            <TaskStatusChip Status="@task.Status" />
                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)">@task.Priority</MudChip>
                            @if (IsTaskOverdue(task))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">Overdue</MudChip>
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>

                <MudPaper Class="glass-card pa-0" Elevation="0">
                    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                        <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Info">
                            <MudText Typo="Typo.subtitle1" Class="mb-2">Description</MudText>
                            @if (!string.IsNullOrEmpty(task.Description))
                            {
                                <MudText Typo="Typo.body1" Class="mb-6">@task.Description</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">No description provided</MudText>
                            }

                            <MudGrid Spacing="3">
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle1" Class="mb-3">Project Information</MudText>
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Project</MudText>
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@task.ProjectName</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Assigned By</MudText>
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@(task.AssignedBy?.FullName ?? "-")</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Created</MudText>
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@(task.CreatedAt?.ToString("MMM dd, yyyy") ?? "-")</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Last Updated</MudText>
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@(task.UpdatedAt?.ToString("MMM dd, yyyy") ?? "-")</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle1" Class="mb-3">Timeline</MudText>
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Start Date</MudText>
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@(task.StartDate?.ToString("MMM dd, yyyy") ?? "Not set")</MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Due Date</MudText>
                                            <MudText Typo="Typo.body2" Color="@(IsTaskOverdue(task) ? Color.Error : Color.Default)" Style="font-weight: 600;">
                                                @(task.DueDate?.ToString("MMM dd, yyyy") ?? "Not set")
                                            </MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Completed</MudText>
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@(task.CompletedDate?.ToString("MMM dd, yyyy") ?? "-")</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudTabPanel>

                        <MudTabPanel Text="Time Tracking" Icon="@Icons.Material.Filled.Schedule">
                            <MudGrid Spacing="3" Class="mb-4">
                                <MudItem xs="12" sm="4">
                                    <MudPaper Class="pa-4 text-center" Elevation="0" Outlined="true">
                                        <MudText Typo="Typo.h4">@(task.EstimatedHours?.ToString() ?? "-")</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Estimated Hours</MudText>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudPaper Class="pa-4 text-center" Elevation="0" Outlined="true">
                                        <MudText Typo="Typo.h4">@task.ActualHours</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Actual Hours</MudText>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudPaper Class="pa-4 text-center" Elevation="0" Outlined="true">
                                        <MudText Typo="Typo.h4">
                                            @if (task.EstimatedHours.HasValue && task.EstimatedHours.Value > 0)
                                            {
                                                @($"{Math.Round((double)task.ActualHours / (double)task.EstimatedHours.Value * 100, 0)}%")
                                            }
                                            else
                                            {
                                                @("-")
                                            }
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Progress</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                            @if (task.EstimatedHours.HasValue && task.EstimatedHours.Value > 0)
                            {
                                var progress = Math.Min((double)task.ActualHours / (double)task.EstimatedHours.Value * 100, 100);
                                <MudProgressLinear Value="@progress"
                                                   Color="@(progress > 100 ? Color.Error : Color.Primary)"
                                                   Size="Size.Large"
                                                   Rounded="true"
                                                   Class="mb-4" />
                            }

                            <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.End">
                                <MudNumericField T="decimal" @bind-Value="_logHours" Label="Hours" Variant="Variant.Outlined"
                                                 Min="0.25m" Max="24m" Step="0.25m" Style="max-width: 120px;" Dense="true" />
                                <MudTextField @bind-Value="_logNotes" Label="Notes" Variant="Variant.Outlined" Dense="true" Style="min-width: 200px;" />
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LogTimeAsync" Disabled="_phase6Busy">
                                    Log time
                                </MudButton>
                            </MudStack>
                            @if (_timeEntries.Count > 0)
                            {
                                <MudTable Items="_timeEntries" Dense="true" Hover="true">
                                    <HeaderContent>
                                        <MudTh>Date</MudTh>
                                        <MudTh>Hours</MudTh>
                                        <MudTh>Notes</MudTh>
                                        <MudTh></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.WorkDate.ToString("MMM d")</MudTd>
                                        <MudTd>@context.Hours.ToString("0.##")</MudTd>
                                        <MudTd>@context.Notes</MudTd>
                                        <MudTd>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           OnClick="@(() => DeleteTimeEntryAsync(context.Id))" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudTabPanel>

                        <MudTabPanel Text="Dependencies" Icon="@Icons.Material.Filled.AccountTree">
                            <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.End">
                                <MudSelect T="int?" @bind-Value="_depPredecessorId" Label="Predecessor" Variant="Variant.Outlined" Dense="true" Style="min-width: 240px;">
                                    @foreach (var t in _projectTasks.Where(t => t.Id != task.Id))
                                    {
                                        <MudSelectItem T="int?" Value="@t.Id">@t.Title</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddDependencyAsync" Disabled="_phase6Busy">
                                    Blocks this task
                                </MudButton>
                            </MudStack>
                            @if (_dependencies.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info">No dependencies yet.</MudAlert>
                            }
                            else
                            {
                                @foreach (var d in _dependencies)
                                {
                                    <MudChip T="string" OnClose="@(() => RemoveDependencyAsync(d.Id))" Class="ma-1">
                                        @d.PredecessorTitle → @d.SuccessorTitle
                                    </MudChip>
                                }
                            }
                        </MudTabPanel>

                        <MudTabPanel Text="Recurrence" Icon="@Icons.Material.Filled.Repeat">
                            <MudSelect T="string" @bind-Value="_recurrenceFreq" Label="Frequency" Variant="Variant.Outlined" Dense="true" Class="mb-3" Style="max-width: 240px;">
                                <MudSelectItem Value="@("none")">None</MudSelectItem>
                                <MudSelectItem Value="@("daily")">Daily</MudSelectItem>
                                <MudSelectItem Value="@("weekly")">Weekly</MudSelectItem>
                                <MudSelectItem Value="@("monthly")">Monthly</MudSelectItem>
                            </MudSelect>
                            <MudNumericField T="int" @bind-Value="_recurrenceInterval" Label="Every N" Variant="Variant.Outlined"
                                             Min="1" Max="365" Dense="true" Class="mb-3" Style="max-width: 160px;" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveRecurrenceAsync" Disabled="_phase6Busy">
                                Save recurrence
                            </MudButton>
                            @if (task.NextOccurrenceAt.HasValue)
                            {
                                <MudText Typo="Typo.caption" Class="mt-2" Color="Color.Secondary">
                                    Next occurrence: @task.NextOccurrenceAt.Value.ToLocalTime().ToString("g")
                                </MudText>
                            }
                        </MudTabPanel>

                        @if (task.History.Any())
                        {
                            <MudTabPanel Text="History" Icon="@Icons.Material.Filled.History">
                                <MudTimeline TimelinePosition="TimelinePosition.Start">
                                    @foreach (var history in task.History.OrderByDescending(h => h.ChangedAt))
                                    {
                                        <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                                            <MudText Typo="Typo.subtitle2">@history.FieldName Changed</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                                @history.ChangedAt.ToString("MMM dd, yyyy HH:mm") � @history.ChangedBy?.FullName
                                            </MudText>
                                            @if (!string.IsNullOrEmpty(history.OldValue))
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-decoration: line-through;">
                                                    From: @history.OldValue
                                                </MudText>
                                            }
                                            @if (!string.IsNullOrEmpty(history.NewValue))
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Success">
                                                    To: @history.NewValue
                                                </MudText>
                                            }
                                            @if (!string.IsNullOrEmpty(history.Comment))
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1" Style="font-style: italic;">
                                                    @history.Comment
                                                </MudText>
                                            }
                                        </MudTimelineItem>
                                    }
                                </MudTimeline>
                            </MudTabPanel>
                        }
                    </MudTabs>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Update Task</MudText>
                    <EditForm Model="updateModel" OnValidSubmit="UpdateTaskStatus">
                        <DataAnnotationsValidator />

                        <MudSelect T="string" @bind-Value="updateModel.Status" Label="Status" Variant="Variant.Outlined" Class="mb-4">
                            <MudSelectItem Value="@("Assigned")">Assigned</MudSelectItem>
                            <MudSelectItem Value="@("InProgress")">In Progress</MudSelectItem>
                            <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                        </MudSelect>

                        <MudNumericField @bind-Value="updateModel.ActualHours"
                                         Label="Hours Worked"
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Step="0.5m"
                                         HelperText="Enter the hours you've worked on this task"
                                         Class="mb-4"
                                         For="@(() => updateModel.ActualHours)" />

                        <MudTextField @bind-Value="updateModel.Comment"
                                      Label="Comment (Optional)"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      Placeholder="Add any notes about your progress..."
                                      Class="mb-4" />

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="isUpdating">
                            @if (isUpdating)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Update Status
                        </MudButton>
                    </EditForm>
                </MudPaper>

                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Quick Actions</MudText>
                    <MudStack Spacing="2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick='() => QuickStatusUpdate("InProgress")'
                                   Disabled="@(task.Status == "InProgress" || isUpdating)">
                            Start Working
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick='() => QuickStatusUpdate("Completed")'
                                   Disabled='@(task.Status == "Completed" || isUpdating)'>
                            Mark as Completed
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else
    {
        <AppEmptyState Title="Task not found" Description="This task doesn't exist or you don't have permission to view it.">
            <Actions>
                <MudButton Variant="Variant.Outlined" OnClick="GoBack">Back to My Tasks</MudButton>
            </Actions>
        </AppEmptyState>
    }
</MudContainer>

@code {
    [Parameter]
    public int TaskId { get; set; }

    private TaskDto? task;
    private UpdateTaskStatusDto updateModel = new();
    private bool isLoading = true;
    private bool isUpdating = false;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    private bool _phase6Busy;
    private List<TimeEntryDto> _timeEntries = [];
    private List<TaskDependencyDto> _dependencies = [];
    private List<TaskDto> _projectTasks = [];
    private decimal _logHours = 1;
    private string? _logNotes;
    private int? _depPredecessorId;
    private string _recurrenceFreq = "none";
    private int _recurrenceInterval = 1;

    protected override async Task OnInitializedAsync() => await LoadTask();

    private async Task LoadTask()
    {
        isLoading = true;
        try
        {
            task = await ApiService.GetTaskAsync(TaskId);
            if (task != null)
            {
                updateModel = new UpdateTaskStatusDto
                {
                    Status = task.Status,
                    ActualHours = task.ActualHours
                };
                _recurrenceFreq = string.IsNullOrWhiteSpace(task.RecurrenceFrequency) ? "none" : task.RecurrenceFrequency;
                _recurrenceInterval = Math.Max(1, task.RecurrenceInterval);
                _timeEntries = await ApiService.GetTaskTimeEntriesAsync(TaskId) ?? [];
                _dependencies = await ApiService.GetDependenciesAsync(taskId: TaskId) ?? [];
                _projectTasks = (await ApiService.GetTasksAsync(task.ProjectId))?.Where(t => t.Id.HasValue).ToList() ?? [];
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading task: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateTaskStatus()
    {
        isUpdating = true;
        successMessage = string.Empty;
        errorMessage = string.Empty;

        try
        {
            var result = await ApiService.UpdateTaskStatusAsync(TaskId, updateModel);
            if (result != null)
            {
                successMessage = "Task status updated successfully!";
                await LoadTask();
            }
            else
            {
                errorMessage = "Failed to update task status. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isUpdating = false;
        }
    }

    private async Task QuickStatusUpdate(string status)
    {
        updateModel.Status = status;
        await UpdateTaskStatus();
    }

    private async Task LogTimeAsync()
    {
        if (task?.Id is not int id) return;
        _phase6Busy = true;
        try
        {
            var (entry, _) = await ApiService.CreateTimeEntryAsync(new CreateTimeEntryDto
            {
                TaskId = id,
                WorkDate = DateTime.UtcNow.Date,
                Hours = _logHours,
                Notes = _logNotes
            });
            if (entry is not null)
            {
                _logNotes = null;
                await LoadTask();
            }
        }
        finally { _phase6Busy = false; }
    }

    private async Task DeleteTimeEntryAsync(int entryId)
    {
        if (await ApiService.DeleteTimeEntryAsync(entryId))
            await LoadTask();
    }

    private async Task AddDependencyAsync()
    {
        if (task?.Id is not int succ || _depPredecessorId is not int pred) return;
        _phase6Busy = true;
        try
        {
            var (dep, _) = await ApiService.CreateDependencyAsync(new CreateTaskDependencyDto
            {
                PredecessorTaskId = pred,
                SuccessorTaskId = succ
            });
            if (dep is not null)
                await LoadTask();
        }
        finally { _phase6Busy = false; }
    }

    private async Task RemoveDependencyAsync(int depId)
    {
        if (await ApiService.DeleteDependencyAsync(depId))
            await LoadTask();
    }

    private async Task SaveRecurrenceAsync()
    {
        if (task?.Id is not int id) return;
        _phase6Busy = true;
        try
        {
            var updated = await ApiService.SetTaskRecurrenceAsync(id, new SetRecurrenceDto
            {
                Frequency = _recurrenceFreq,
                Interval = _recurrenceInterval
            });
            if (updated is not null)
                await LoadTask();
        }
        finally { _phase6Busy = false; }
    }

    private void GoBack() => Navigation.NavigateTo("/user/tasks");

    private static bool IsTaskOverdue(TaskDto task) =>
        task.DueDate.HasValue &&
        task.DueDate.Value < DateTime.Today &&
        task.Status is not ("Completed" or "Tested" or "Closed");

    private static Color GetPriorityColor(string priority) => priority switch
    {
        "Low" => Color.Success,
        "Medium" => Color.Info,
        "High" => Color.Warning,
        "Critical" => Color.Error,
        _ => Color.Default
    };
}
