@* TaskManager.Client/Pages/User/Dashboard.razor *@
@page "/user/dashboard"
@attribute [Authorize(Roles = "User")]
@inject IApiService ApiService
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>My Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    @if (isLoading)
    {
        <AppLoading Message="Loading dashboard..." />
    }
    else if (dashboardData != null)
    {
        <MudGrid Spacing="4" Class="mb-4">
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.TotalProjects.ToString()"
                             Label="My Projects"
                             Icon="@Icons.Material.Filled.Folder"
                             IconColor="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.TotalTasks.ToString()"
                             Label="Assigned Tasks"
                             Icon="@Icons.Material.Filled.TaskAlt"
                             IconColor="Color.Info" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.InProgressTasks.ToString()"
                             Label="In Progress"
                             Icon="@Icons.Material.Filled.HourglassTop"
                             IconColor="Color.Warning" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.CompletedTasks.ToString()"
                             Label="Completed"
                             Icon="@Icons.Material.Filled.CheckCircle"
                             IconColor="Color.Success" />
            </MudItem>
        </MudGrid>

        @if (dashboardData.OverdueTasks > 0)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" Icon="@Icons.Material.Filled.Warning">
                <strong>Urgent!</strong> You have @dashboardData.OverdueTasks overdue tasks that need immediate attention.
            </MudAlert>
        }

        <MudGrid Spacing="4">
            <MudItem xs="12" lg="8">
                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">My Recent Tasks</MudText>
                    @if (dashboardData.RecentTasks.Any())
                    {
                        <MudStack Spacing="2">
                            @foreach (var task in dashboardData.RecentTasks)
                            {
                                <MudPaper Class="pa-3" Elevation="0" Style="background: rgba(255,255,255,0.03);">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-2">
                                        <div>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@task.Title</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@task.ProjectName</MudText>
                                        </div>
                                        <TaskStatusChip Status="@task.Status" />
                                    </MudStack>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="flex-wrap gap-2">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)">@task.Priority</MudChip>
                                            @if (task.DueDate.HasValue)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    Due: @task.DueDate.Value.ToString("MMM dd, yyyy")
                                                </MudText>
                                            }
                                        </MudStack>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @task.ActualHours / @(task.EstimatedHours?.ToString() ?? "-") hrs
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <AppEmptyState Title="No tasks assigned yet" />
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Upcoming Deadlines</MudText>
                    @if (dashboardData.UpcomingDeadlines.Any())
                    {
                        <MudStack Spacing="2">
                            @foreach (var task in dashboardData.UpcomingDeadlines)
                            {
                                <MudPaper Class="pa-3" Elevation="0" Style="background: rgba(255,255,255,0.03);">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@task.Title</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">@task.ProjectName</MudText>
                                    @if (task.DueDate.HasValue)
                                    {
                                        var daysUntil = (task.DueDate.Value - DateTime.Today).Days;
                                        @if (daysUntil == 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Due Today!</MudChip>
                                        }
                                        else if (daysUntil == 1)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Due Tomorrow</MudChip>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="@(daysUntil <= 2 ? Color.Error : Color.Secondary)">
                                                Due in @daysUntil days
                                            </MudText>
                                        }
                                    }
                                </MudPaper>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <AppEmptyState Title="No upcoming deadlines" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private DashboardDto? dashboardData;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        try
        {
            dashboardData = await ApiService.GetDashboardDataAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private static Color GetPriorityColor(string priority) => priority switch
    {
        "Low" => Color.Success,
        "Medium" => Color.Warning,
        "High" => Color.Error,
        "Critical" => Color.Error,
        _ => Color.Default
    };
}
