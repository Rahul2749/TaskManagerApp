@page "/forgot-password"
@layout LoginLayout
@using TaskManager.Client.Components.Layout
@inject IAuthServiceClient AuthService
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="auth-page-wrapper">
    <MudPaper Class="glass-card auth-card pa-8" Elevation="0">
        <MudStack AlignItems="AlignItems.Center" Class="mb-6">
            <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.VpnKey" />
            </MudAvatar>
            <MudText Typo="Typo.h5">Forgot Password?</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                Enter your email and we'll send a link to reset your password.
            </MudText>
        </MudStack>

        @if (isSuccess)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Check your inbox</MudText>
                <MudText Typo="Typo.body2">
                    If an account exists for <strong>@email</strong>, a reset link is on its way.
                </MudText>
            </MudAlert>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="BackToLogin">
                Back to Login
            </MudButton>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@errorMessage</MudAlert>
            }

            <EditForm Model="formModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="formModel.Email"
                              Label="Email Address"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Placeholder="Enter your email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              Class="mb-4"
                              For="@(() => formModel.Email)" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="isLoading"
                           EndIcon="@Icons.Material.Filled.Send">
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send Reset Link</span>
                    }
                </MudButton>
            </EditForm>

            <MudDivider Class="my-6" />
            <MudStack Row="true" Justify="Justify.Center">
                <MudLink Href="/login" Typo="Typo.body2">Back to Login</MudLink>
            </MudStack>
        }
    </MudPaper>
</div>

<style>
    .auth-page-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .auth-card {
        width: 100%;
        max-width: 460px;
    }
</style>

@code {
    private ForgotPasswordModel formModel = new();
    private string email => formModel.Email;
    private bool isLoading;
    private bool isSuccess;
    private string errorMessage = string.Empty;

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var result = await AuthService.ForgotPasswordAsync(formModel.Email.Trim());
            if (result.Success)
                isSuccess = true;
            else
                errorMessage = result.Error ?? "An error occurred. Please try again later.";
        }
        catch
        {
            errorMessage = "An error occurred. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void BackToLogin() => Navigation.NavigateTo("/login");

    private class ForgotPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please enter your email address.")]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
