@page "/sso-callback"
@layout TaskManager.Client.Components.Layout.LoginLayout
@inject IAuthServiceClient AuthService
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<MudContainer MaxWidth="MaxWidth.Small" Class="py-10">
    <MudPaper Class="pa-6 glass-card" Elevation="0">
        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary">Back to login</MudButton>
        }
        else
        {
            <AppLoading Message="Completing sign-in..." />
        }
    </MudPaper>
</MudContainer>

@code {
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var code = GetQueryParam("code");
        if (string.IsNullOrWhiteSpace(code))
        {
            _error = "Missing SSO code.";
            return;
        }

        var ok = await AuthService.CompleteSsoLoginAsync(code);
        if (!ok)
        {
            _error = "Could not complete SSO login. The link may have expired.";
            return;
        }

        var user = await AuthService.GetCurrentUserAsync();
        Navigation.NavigateTo(GetHome(user?.Role), forceLoad: true);
    }

    private string? GetQueryParam(string key)
    {
        var uri = new Uri(Navigation.Uri);
        var query = uri.Query.TrimStart('?');
        foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && string.Equals(Uri.UnescapeDataString(kv[0]), key, StringComparison.OrdinalIgnoreCase))
                return Uri.UnescapeDataString(kv[1]);
        }
        return null;
    }

    private static string GetHome(string? role) => role switch
    {
        "SuperAdmin" => "/superadmin/dashboard",
        "OrganizationAdmin" => "/admin/dashboard",
        "Manager" => "/manager/dashboard",
        _ => "/user/dashboard"
    };
}
