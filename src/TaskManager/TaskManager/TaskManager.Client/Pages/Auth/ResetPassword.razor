@* Components/Pages/ResetPassword.razor *@
@page "/reset-password"
@using TaskManager.Client.Components.Layout
@layout LoginLayout
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="reset-wrapper">
    <div class="reset-container">
        <div class="reset-card">
            @if (isSuccess)
            {
                <!-- Success State -->
                <div class="success-content">
                    <div class="icon-wrapper success-icon">
                        <span class="icon">✅</span>
                    </div>
                    <h1 class="reset-title">Password Reset!</h1>
                    <p class="reset-subtitle">Your password has been successfully reset. You can now login with your new password.</p>
                    <button type="button" class="btn btn-primary btn-submit" @onclick="GoToLogin">
                        <span>Go to Login</span>
                        <span class="btn-arrow">→</span>
                    </button>
                </div>
            }
            else
            {
                <!-- Form State -->
                <div class="reset-header">
                    <div class="icon-wrapper">
                        <span class="icon">🔒</span>
                    </div>
                    <h1 class="reset-title">Create New Password</h1>
                    <p class="reset-subtitle">Your new password must be different from previously used passwords.</p>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-error">
                        <span class="alert-icon">⚠️</span>
                        <span class="alert-text">@errorMessage</span>
                    </div>
                }

                <form class="reset-form" @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                    <div class="form-group">
                        <label class="form-label">Verification Code</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔢</span>
                            <input type="text" class="form-control" @bind="verificationCode" placeholder="Enter 6-digit code" maxlength="6" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">New Password</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="@(showPassword ? "text" : "password")" class="form-control" @bind="newPassword" placeholder="Enter new password" required />
                            <button type="button" class="toggle-password" @onclick="TogglePassword">
                                @(showPassword ? "👁️" : "👁️‍🗨️")
                            </button>
                        </div>
                        <div class="password-strength">
                            <div class="strength-bar @GetStrengthClass()">
                                <div class="strength-fill"></div>
                            </div>
                            <span class="strength-text">@GetStrengthText()</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" class="form-control" @bind="confirmPassword" placeholder="Confirm new password" required />
                        </div>
                    </div>

                    <div class="password-requirements">
                        <p class="requirements-title">Password must contain:</p>
                        <div class="requirement @(newPassword.Length >= 8 ? "valid" : "")">
                            <span class="check">@(newPassword.Length >= 8 ? "✓" : "○")</span>
                            <span>At least 8 characters</span>
                        </div>
                        <div class="requirement @(HasUpperCase() ? "valid" : "")">
                            <span class="check">@(HasUpperCase() ? "✓" : "○")</span>
                            <span>One uppercase letter</span>
                        </div>
                        <div class="requirement @(HasLowerCase() ? "valid" : "")">
                            <span class="check">@(HasLowerCase() ? "✓" : "○")</span>
                            <span>One lowercase letter</span>
                        </div>
                        <div class="requirement @(HasNumber() ? "valid" : "")">
                            <span class="check">@(HasNumber() ? "✓" : "○")</span>
                            <span>One number</span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-submit" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-loading"></span>
                            <span>Resetting...</span>
                        }
                        else
                        {
                            <span>Reset Password</span>
                            <span class="btn-arrow">→</span>
                        }
                    </button>
                </form>

                <div class="reset-footer">
                    <a href="/login" class="back-link">
                        <span class="back-arrow">←</span>
                        <span>Back to Login</span>
                    </a>
                </div>
            }
        </div>

        <div class="decorative-circles">
            <div class="circle circle-1"></div>
            <div class="circle circle-2"></div>
            <div class="circle circle-3"></div>
        </div>
    </div>
</div>

<style>
    .reset-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(180deg, #F8F9FE 0%, #FFFFFF 50%, #F8F9FE 100%);
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }

    .reset-wrapper::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: 
            radial-gradient(circle at 20% 50%, rgba(67, 24, 255, 0.03) 0%, transparent 50%),
            radial-gradient(circle at 80% 80%, rgba(117, 81, 255, 0.03) 0%, transparent 50%);
        pointer-events: none;
    }

    .reset-container {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 500px;
    }

    .reset-card {
        background: white;
        border-radius: 32px;
        padding: 3rem 2.5rem;
        box-shadow: 0 20px 60px rgba(43, 54, 116, 0.12);
        border: 1px solid rgba(67, 24, 255, 0.08);
    }

    .reset-header, .success-content {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .icon-wrapper {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, rgba(67, 24, 255, 0.1), rgba(117, 81, 255, 0.1));
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(67, 24, 255, 0.15);
    }

    .success-icon {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(5, 150, 105, 0.1));
        border-color: rgba(16, 185, 129, 0.15);
    }

    .icon {
        font-size: 2.5rem;
    }

    .reset-title {
        font-size: 2rem;
        font-weight: 800;
        color: #2B3674;
        margin: 0 0 0.75rem;
        letter-spacing: -0.02em;
    }

    .reset-subtitle {
        color: #707EAE;
        font-size: 0.9375rem;
        margin: 0;
        line-height: 1.6;
    }

    .alert {
        padding: 14px 16px;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        animation: slideDown 0.3s ease;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .alert-error {
        background: #FEE2E2;
        color: #991B1B;
        border: 1px solid #FCA5A5;
    }

    .alert-icon {
        font-size: 1.125rem;
        flex-shrink: 0;
    }

    .alert-text {
        flex: 1;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .reset-form {
        margin-bottom: 1.5rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: #2B3674;
        font-size: 0.875rem;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 16px;
        font-size: 1.125rem;
        pointer-events: none;
        z-index: 1;
    }

    .form-control {
        width: 100%;
        padding: 14px 48px 14px 48px;
        border: 2px solid rgba(67, 24, 255, 0.15);
        border-radius: 12px;
        font-size: 0.9375rem;
        transition: all 0.2s;
        background: white;
        color: #2B3674;
        font-family: inherit;
    }

    .form-control:focus {
        outline: none;
        border-color: #4318FF;
        box-shadow: 0 0 0 4px rgba(67, 24, 255, 0.1);
    }

    .form-control::placeholder {
        color: #A3AED0;
    }

    .toggle-password {
        position: absolute;
        right: 16px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.125rem;
        padding: 4px;
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .toggle-password:hover {
        opacity: 1;
    }

    .password-strength {
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .strength-bar {
        flex: 1;
        height: 6px;
        background: #E2E8F0;
        border-radius: 3px;
        overflow: hidden;
    }

    .strength-fill {
        height: 100%;
        width: 0%;
        transition: all 0.3s;
        border-radius: 3px;
    }

    .strength-bar.weak .strength-fill {
        width: 33%;
        background: #DC2626;
    }

    .strength-bar.medium .strength-fill {
        width: 66%;
        background: #F59E0B;
    }

    .strength-bar.strong .strength-fill {
        width: 100%;
        background: #10B981;
    }

    .strength-text {
        font-size: 0.8125rem;
        font-weight: 600;
        min-width: 60px;
    }

    .strength-bar.weak ~ .strength-text {
        color: #DC2626;
    }

    .strength-bar.medium ~ .strength-text {
        color: #F59E0B;
    }

    .strength-bar.strong ~ .strength-text {
        color: #10B981;
    }

    .password-requirements {
        background: #F8F9FE;
        padding: 1rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(67, 24, 255, 0.1);
    }

    .requirements-title {
        font-size: 0.8125rem;
        font-weight: 700;
        color: #2B3674;
        margin: 0 0 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .requirement {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: #707EAE;
        margin-bottom: 0.5rem;
    }

    .requirement:last-child {
        margin-bottom: 0;
    }

    .requirement.valid {
        color: #10B981;
    }

    .requirement .check {
        font-weight: 700;
        font-size: 1rem;
    }

    .btn-submit {
        width: 100%;
        padding: 16px 24px;
        font-size: 1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        height: 56px;
        background: linear-gradient(135deg, #4318FF 0%, #7551FF 100%);
        border: none;
        border-radius: 12px;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(67, 24, 255, 0.3);
    }

    .btn-submit:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 12px 35px rgba(67, 24, 255, 0.4);
    }

    .btn-submit:active:not(:disabled) {
        transform: translateY(0);
    }

    .btn-submit:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .btn-arrow {
        transition: transform 0.2s;
        font-size: 1.125rem;
    }

    .btn-submit:hover:not(:disabled) .btn-arrow {
        transform: translateX(4px);
    }

    .spinner-loading {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .reset-footer {
        text-align: center;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(67, 24, 255, 0.1);
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #4318FF;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9375rem;
        transition: all 0.2s;
    }

    .back-link:hover {
        color: #7551FF;
        gap: 12px;
    }

    .back-arrow {
        transition: transform 0.2s;
        font-size: 1.125rem;
    }

    .back-link:hover .back-arrow {
        transform: translateX(-4px);
    }

    .decorative-circles {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .circle {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(67, 24, 255, 0.04), transparent 70%);
        animation: float 20s infinite ease-in-out;
    }

    .circle-1 {
        width: 500px;
        height: 500px;
        top: -250px;
        right: -200px;
    }

    .circle-2 {
        width: 400px;
        height: 400px;
        bottom: -150px;
        left: -150px;
        animation-delay: 3s;
    }

    .circle-3 {
        width: 300px;
        height: 300px;
        top: 50%;
        left: -150px;
        animation-delay: 6s;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-30px) scale(1.05); }
    }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .reset-wrapper { padding: 1.5rem; }
        .reset-card { padding: 2.5rem 2rem; border-radius: 24px; }
        .reset-title { font-size: 1.75rem; }
        .icon-wrapper { width: 70px; height: 70px; }
        .icon { font-size: 2.25rem; }
    }

    @@media (max-width: 480px) {
        .reset-wrapper { padding: 1rem; }
        .reset-card { padding: 2rem 1.5rem; }
        .reset-title { font-size: 1.5rem; }
        .icon-wrapper { width: 60px; height: 60px; }
        .icon { font-size: 2rem; }
        .form-control { padding: 12px 44px 12px 44px; font-size: 0.875rem; }
        .input-icon { font-size: 1rem; left: 14px; }
        .btn-submit { font-size: 0.9375rem; height: 52px; }
        .circle-1 { width: 350px; height: 350px; }
        .circle-2 { width: 300px; height: 300px; }
        .circle-3 { display: none; }
    }

    @@media (hover: none) and (pointer: coarse) {
        .form-control { font-size: 16px; }
    }
</style>

@code {
    private string verificationCode = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private bool showPassword = false;
    private bool isLoading = false;
    private bool isSuccess = false;
    private string errorMessage = string.Empty;

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    private bool HasUpperCase()
    {
        return newPassword.Any(char.IsUpper);
    }

    private bool HasLowerCase()
    {
        return newPassword.Any(char.IsLower);
    }

    private bool HasNumber()
    {
        return newPassword.Any(char.IsDigit);
    }

    private string GetStrengthClass()
    {
        if (string.IsNullOrEmpty(newPassword)) return "";
        
        int strength = 0;
        if (newPassword.Length >= 8) strength++;
        if (HasUpperCase()) strength++;
        if (HasLowerCase()) strength++;
        if (HasNumber()) strength++;

        if (strength < 2) return "weak";
        if (strength < 4) return "medium";
        return "strong";
    }

    private string GetStrengthText()
    {
        if (string.IsNullOrEmpty(newPassword)) return "";
        
        var strengthClass = GetStrengthClass();
        if (strengthClass == "weak") return "Weak";
        if (strengthClass == "medium") return "Medium";
        if (strengthClass == "strong") return "Strong";
        return "";
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(verificationCode))
        {
            errorMessage = "Please enter the verification code.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            errorMessage = "Please enter a new password.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        if (newPassword.Length < 8 || !HasUpperCase() || !HasLowerCase() || !HasNumber())
        {
            errorMessage = "Password does not meet requirements.";
            return;
        }

        isLoading = true;

        try
        {
            await Task.Delay(1500);
            // TODO: Call API to reset password
            // await PasswordService.ResetPasswordAsync(verificationCode, newPassword);
            isSuccess = true;
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred. Please try again.";
            Console.WriteLine($"Reset password error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
}