@* Components/Pages/ResetPassword.razor *@
@page "/reset-password"
@using TaskManager.Client.Components
@using TaskManager.Client.Components.Layout
@layout LoginLayout
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="auth-page-wrapper">
    <MudPaper Class="glass-card auth-card pa-8" Elevation="0">
        @if (isSuccess)
        {
            <MudStack AlignItems="AlignItems.Center">
                <MudAvatar Color="Color.Success" Size="Size.Large" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                </MudAvatar>
                <MudText Typo="Typo.h5" Class="mb-2">Password Reset!</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mb-6">
                    Your password has been successfully reset. You can now login with your new password.
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           EndIcon="@Icons.Material.Filled.Login"
                           OnClick="GoToLogin">
                    Go to Login
                </MudButton>
            </MudStack>
        }
        else
        {
            <MudStack AlignItems="AlignItems.Center" Class="mb-6">
                <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" />
                </MudAvatar>
                <MudText Typo="Typo.h5">Create New Password</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    Your new password must be different from previously used passwords.
                </MudText>
            </MudStack>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@errorMessage</MudAlert>
            }

            <MudTextField @bind-Value="verificationCode"
                          Label="Verification Code"
                          Variant="Variant.Outlined"
                          Placeholder="Enter 6-digit code"
                          MaxLength="6"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Pin"
                          Class="mb-4" />

            <MudTextField @bind-Value="newPassword"
                          Label="New Password"
                          Variant="Variant.Outlined"
                          InputType="@(showPassword ? InputType.Text : InputType.Password)"
                          Placeholder="Enter new password"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="TogglePassword"
                          Class="mb-2" />

            @if (!string.IsNullOrEmpty(newPassword))
            {
                <MudProgressLinear Color="@GetStrengthColor()" Value="@GetStrengthValue()" Class="mb-1" />
                <MudText Typo="Typo.caption" Color="@GetStrengthColor()" Class="mb-4">@GetStrengthText()</MudText>
            }
            else
            {
                <div class="mb-4" />
            }

            <MudTextField @bind-Value="confirmPassword"
                          Label="Confirm Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Placeholder="Confirm new password"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock"
                          Class="mb-4" />

            <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">PASSWORD REQUIREMENTS</MudText>
                <MudStack Spacing="1">
                    @foreach (var req in GetRequirements())
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@(req.Met ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.RadioButtonUnchecked)"
                                     Color="@(req.Met ? Color.Success : Color.Default)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.body2" Color="@(req.Met ? Color.Success : Color.Secondary)">@req.Text</MudText>
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="isLoading"
                       EndIcon="@Icons.Material.Filled.Check"
                       OnClick="HandleSubmit">
                @if (isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Resetting...</span>
                }
                else
                {
                    <span>Reset Password</span>
                }
            </MudButton>

            <MudDivider Class="my-6" />
            <MudStack Row="true" Justify="Justify.Center">
                <MudLink Href="/login" Typo="Typo.body2">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="mr-1" />
                    Back to Login
                </MudLink>
            </MudStack>
        }
    </MudPaper>
</div>

<style>
    .auth-page-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .auth-card {
        width: 100%;
        max-width: 500px;
    }
</style>

@code {
    private string verificationCode = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private bool showPassword = false;
    private bool isLoading = false;
    private bool isSuccess = false;
    private string errorMessage = string.Empty;

    private void TogglePassword() => showPassword = !showPassword;

    private bool HasUpperCase() => newPassword.Any(char.IsUpper);
    private bool HasLowerCase() => newPassword.Any(char.IsLower);
    private bool HasNumber() => newPassword.Any(char.IsDigit);

    private int GetStrengthScore()
    {
        if (string.IsNullOrEmpty(newPassword)) return 0;
        var score = 0;
        if (newPassword.Length >= 8) score++;
        if (HasUpperCase()) score++;
        if (HasLowerCase()) score++;
        if (HasNumber()) score++;
        return score;
    }

    private Color GetStrengthColor()
    {
        var score = GetStrengthScore();
        if (score < 2) return Color.Error;
        if (score < 4) return Color.Warning;
        return Color.Success;
    }

    private double GetStrengthValue()
    {
        return GetStrengthScore() switch
        {
            0 => 0,
            1 => 25,
            2 => 50,
            3 => 75,
            _ => 100
        };
    }

    private string GetStrengthText()
    {
        var score = GetStrengthScore();
        if (score < 2) return "Weak";
        if (score < 4) return "Medium";
        return "Strong";
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(verificationCode))
        {
            errorMessage = "Please enter the verification code.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            errorMessage = "Please enter a new password.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        if (newPassword.Length < 8 || !HasUpperCase() || !HasLowerCase() || !HasNumber())
        {
            errorMessage = "Password does not meet requirements.";
            return;
        }

        isLoading = true;

        try
        {
            await Task.Delay(1500);
            isSuccess = true;
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred. Please try again.";
            Console.WriteLine($"Reset password error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToLogin() => Navigation.NavigateTo("/login");

    private List<(bool Met, string Text)> GetRequirements() => new()
    {
        (newPassword.Length >= 8, "At least 8 characters"),
        (HasUpperCase(), "One uppercase letter"),
        (HasLowerCase(), "One lowercase letter"),
        (HasNumber(), "One number")
    };
}
