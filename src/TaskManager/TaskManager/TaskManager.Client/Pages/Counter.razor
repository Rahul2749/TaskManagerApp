@page "/counter"
@rendermode InteractiveWebAssembly

<PageTitle>Counter</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
    <MudText Typo="Typo.h4" Class="mb-4">Counter</MudText>
    <MudText Typo="Typo.body1" Class="mb-4" role="status">Current count: @currentCount</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="IncrementCount">Click me</MudButton>
</MudContainer>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
