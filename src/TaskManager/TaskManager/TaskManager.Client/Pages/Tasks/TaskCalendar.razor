@page "/calendar"
@page "/manager/calendar"
@page "/user/calendar"
@page "/admin/calendar"
@attribute [Authorize(Roles = "OrganizationAdmin,Manager,User")]
@using TaskManager.Shared.Billing
@inject IApiService ApiService
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Calendar</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    <AppPageHeader Title="Calendar" Subtitle="Tasks by due date">
        <Actions>
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="PrevMonth" title="Previous month" />
            <MudText Typo="Typo.subtitle1" Class="mx-2" Style="min-width: 160px; text-align: center;">
                @_month.ToString("MMMM yyyy")
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="NextMonth" title="Next month" />
            <MudIconButton Icon="@Icons.Material.Filled.Today" OnClick="GoToday" title="Today" />
        </Actions>
    </AppPageHeader>

    <FeatureGate Feature="@FeatureKeys.CalendarView" FeatureLabel="Calendar view">
        @if (_loading)
        {
            <AppLoading Message="Loading calendar..." />
        }
        else
        {
            <MudPaper Class="glass-card pa-3" Elevation="0">
                <div class="cal-grid cal-head">
                    @foreach (var day in DayNames)
                    {
                        <div class="cal-cell cal-head-cell">@day</div>
                    }
                </div>
                <div class="cal-grid">
                    @foreach (var cell in _cells)
                    {
                        <div class="cal-cell @(cell.IsCurrentMonth ? "" : "cal-muted") @(cell.IsToday ? "cal-today" : "")">
                            <div class="cal-daynum">@cell.Date.Day</div>
                            @foreach (var task in cell.Tasks.Take(3))
                            {
                                <button type="button" class="cal-task" @onclick="@(() => OpenTask(task))">
                                    @task.Title
                                </button>
                            }
                            @if (cell.Tasks.Count > 3)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">+@(cell.Tasks.Count - 3) more</MudText>
                            }
                        </div>
                    }
                </div>
            </MudPaper>
        }
    </FeatureGate>
</MudContainer>

<style>
    .cal-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 1px;
        background: rgba(255, 255, 255, 0.06);
    }

    .cal-head {
        margin-bottom: 1px;
        background: transparent;
        gap: 0;
    }

    .cal-cell {
        min-height: 110px;
        background: var(--mud-palette-surface);
        padding: 0.5rem;
    }

    .cal-head-cell {
        min-height: auto;
        background: transparent;
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        text-align: center;
        padding: 0.5rem;
    }

    .cal-muted {
        opacity: 0.45;
    }

    .cal-today {
        outline: 1px solid var(--mud-palette-primary);
        outline-offset: -1px;
    }

    .cal-daynum {
        font-size: 0.8rem;
        margin-bottom: 0.35rem;
        font-weight: 600;
    }

    .cal-task {
        display: block;
        width: 100%;
        text-align: left;
        border: none;
        background: rgba(79, 70, 229, 0.2);
        color: inherit;
        border-radius: 4px;
        padding: 0.2rem 0.35rem;
        margin-bottom: 0.25rem;
        font-size: 0.7rem;
        cursor: pointer;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .cal-task:hover {
        background: rgba(79, 70, 229, 0.35);
    }
</style>

@code {
    private static readonly string[] DayNames = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

    private DateTime _month = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private List<TaskDto> _tasks = [];
    private List<CalendarCell> _cells = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            _tasks = await ApiService.GetTasksAsync() ?? [];
            BuildCells();
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildCells()
    {
        var first = _month;
        var start = first.AddDays(-(int)first.DayOfWeek);
        var cells = new List<CalendarCell>();
        for (var i = 0; i < 42; i++)
        {
            var date = start.AddDays(i).Date;
            var dayTasks = _tasks
                .Where(t => t.DueDate?.Date == date)
                .OrderBy(t => t.Title)
                .ToList();
            cells.Add(new CalendarCell
            {
                Date = date,
                IsCurrentMonth = date.Month == _month.Month,
                IsToday = date == DateTime.Today,
                Tasks = dayTasks
            });
        }

        _cells = cells;
    }

    private async Task PrevMonth()
    {
        _month = _month.AddMonths(-1);
        BuildCells();
        await Task.CompletedTask;
    }

    private async Task NextMonth()
    {
        _month = _month.AddMonths(1);
        BuildCells();
        await Task.CompletedTask;
    }

    private async Task GoToday()
    {
        _month = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        BuildCells();
        await Task.CompletedTask;
    }

    private void OpenTask(TaskDto task)
    {
        if (task.Id is null) return;
        if (Navigation.Uri.Contains("/user/", StringComparison.OrdinalIgnoreCase))
            Navigation.NavigateTo($"/user/task/{task.Id}");
    }

    private sealed class CalendarCell
    {
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public bool IsToday { get; set; }
        public List<TaskDto> Tasks { get; set; } = [];
    }
}
