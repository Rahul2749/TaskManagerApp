@* TaskManager.Client/Pages/Admin/ManageManagers.razor *@
@page "/admin/managers"
@attribute [Authorize(Roles = "OrganizationAdmin")]
@inject IApiService ApiService
@inject IJSRuntime JSRuntime
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Manage Managers</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-2">
    <AppPageHeader Title="Manage Managers" Subtitle="Create and manage manager accounts">
        <Actions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                New Manager
            </MudButton>
        </Actions>
    </AppPageHeader>

    @if (isLoading)
    {
        <AppLoading Message="Loading managers..." />
    }
    else if (!managers.Any())
    {
        <AppEmptyState Title="No managers found" Description="Create your first manager!" />
    }
    else
    {
        <MudPaper Class="glass-card pa-0" Elevation="0">
            <MudTable Items="managers" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Username</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Created Date</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Small" Color="Color.Primary">@(context.FirstName?.Substring(0, 1))</MudAvatar>
                            <MudText>@context.FullName</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Username">@context.Username</MudTd>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                            @(context.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Created Date">@context.CreatedAt.ToString("MMM dd, yyyy")</MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" title="Edit" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteManager(context.Id))" title="Delete" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

<MudDialog Visible="showDialog" VisibleChanged="OnDialogVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(isEditMode ? "Edit Manager" : "Create Manager")</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="managerModel" OnValidSubmit="SaveManager">
            <DataAnnotationsValidator />
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@errorMessage</MudAlert>
            }

            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="managerModel.FirstName" Label="First Name" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Enter first name" />
                    <ValidationMessage For="@(() => managerModel.FirstName)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="managerModel.LastName" Label="Last Name" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Enter last name" />
                    <ValidationMessage For="@(() => managerModel.LastName)" />
                </MudItem>
            </MudGrid>

            <MudTextField @bind-Value="managerModel.Username" Label="Username" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Placeholder="Enter username" />
            <ValidationMessage For="@(() => managerModel.Username)" />

            <MudTextField @bind-Value="managerModel.Email" Label="Email" InputType="InputType.Email" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Placeholder="Enter email address" />
            <ValidationMessage For="@(() => managerModel.Email)" />

            <MudTextField @bind-Value="managerModel.Password"
                          Label="@($"Password {(isEditMode ? "(leave blank to keep current)" : "")}")"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mt-2"
                          Placeholder="Enter password" />
            <ValidationMessage For="@(() => managerModel.Password)" />

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                <MudButton OnClick="CloseDialog">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="isSaving">
                    @if (isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @(isEditMode ? "Update Manager" : "Create Manager")
                </MudButton>
            </MudStack>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    private List<UserDto> managers = new();
    private bool isLoading = true;
    private bool showDialog = false;
    private bool isEditMode = false;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private RegisterDto managerModel = new();
    private int editingManagerId = 0;

    private readonly DialogOptions _dialogOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadManagers();
    }

    private async Task LoadManagers()
    {
        isLoading = true;
        try
        {
            managers = await ApiService.GetUsersAsync("Manager") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading managers: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        isEditMode = false;
        managerModel = new RegisterDto { Role = "Manager" };
        errorMessage = string.Empty;
        showDialog = true;
    }

    private void OpenEditDialog(UserDto manager)
    {
        isEditMode = true;
        editingManagerId = manager.Id;
        managerModel = new RegisterDto
        {
            Username = manager.Username,
            Email = manager.Email,
            FirstName = manager.FirstName,
            LastName = manager.LastName,
            Role = "Manager",
            Password = string.Empty
        };
        errorMessage = string.Empty;
        showDialog = true;
    }

    private void CloseDialog()
    {
        showDialog = false;
        managerModel = new();
        errorMessage = string.Empty;
        StateHasChanged();
    }

    private void HandleBackdropClick()
    {
        CloseDialog();
    }

    private void OnDialogVisibleChanged(bool visible)
    {
        if (visible)
            showDialog = true;
        else if (showDialog)
            HandleBackdropClick();
    }

    private async Task SaveManager()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            UserDto? result;

            if (isEditMode)
            {
                result = await ApiService.UpdateUserAsync(editingManagerId, managerModel);
            }
            else
            {
                result = await ApiService.CreateUserAsync(managerModel);
            }

            if (result != null)
            {
                await LoadManagers();
                CloseDialog();
            }
            else
            {
                errorMessage = "Failed to save manager. Username or email may already exist.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteManager(int managerId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this manager?"))
        {
            try
            {
                var success = await ApiService.DeleteUserAsync(managerId);
                if (success)
                {
                    await LoadManagers();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting manager: {ex.Message}");
            }
        }
    }
}
