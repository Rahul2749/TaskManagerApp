@* TaskManager.Client/Pages/Admin/Dashboard.razor *@
@page "/admin/dashboard"
@attribute [Authorize(Roles = "OrganizationAdmin")]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject IApiService ApiService

<PageTitle>Admin Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    @if (isLoading)
    {
        <AppLoading Message="Loading dashboard..." />
    }
    else if (dashboardData != null)
    {
        <MudGrid Spacing="4" Class="mb-4">
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.TotalProjects.ToString()"
                             Label="Total Projects"
                             Meta="@($"{dashboardData.ActiveProjects} active")"
                             Icon="@Icons.Material.Filled.Folder"
                             IconColor="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.TotalTasks.ToString()"
                             Label="Total Tasks"
                             Meta="@($"{dashboardData.InProgressTasks} in progress")"
                             Icon="@Icons.Material.Filled.TaskAlt"
                             IconColor="Color.Info" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.CompletedTasks.ToString()"
                             Label="Completed Tasks"
                             Meta="@($"{(dashboardData.TotalTasks > 0 ? Math.Round((double)dashboardData.CompletedTasks / dashboardData.TotalTasks * 100, 1) : 0)}% completion")"
                             Icon="@Icons.Material.Filled.CheckCircle"
                             IconColor="Color.Success" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.TotalUsers.ToString()"
                             Label="Total Users"
                             Meta="@($"{dashboardData.ActiveUsers} active")"
                             Icon="@Icons.Material.Filled.People"
                             IconColor="Color.Warning" />
            </MudItem>
        </MudGrid>

        @if (dashboardData.OverdueTasks > 0)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4" Icon="@Icons.Material.Filled.Warning">
                <strong>Attention!</strong> There are @dashboardData.OverdueTasks overdue tasks that need attention.
            </MudAlert>
        }

        <MudGrid Spacing="4" Class="mb-4">
            <MudItem xs="12" lg="8">
                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Project Overview</MudText>
                    @if (dashboardData.ProjectSummaries.Any())
                    {
                        <MudTable Items="dashboardData.ProjectSummaries" Hover="true" Dense="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Project Name</MudTh>
                                <MudTh Style="text-align: center;">Total</MudTh>
                                <MudTh Style="text-align: center;">Completed</MudTh>
                                <MudTh Style="text-align: center;">In Progress</MudTh>
                                <MudTh>Progress</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Project Name">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@context.ProjectName</MudText>
                                </MudTd>
                                <MudTd DataLabel="Total" Style="text-align: center;">@context.TotalTasks</MudTd>
                                <MudTd DataLabel="Completed" Style="text-align: center;">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">@context.CompletedTasks</MudChip>
                                </MudTd>
                                <MudTd DataLabel="In Progress" Style="text-align: center;">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.InProgressTasks</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Progress">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudProgressLinear Value="@context.CompletionPercentage" Color="Color.Primary" Class="flex-grow-1" />
                                        <MudText Typo="Typo.caption">@context.CompletionPercentage%</MudText>
                                    </MudStack>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <AppEmptyState Title="No projects found" />
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Recent Tasks</MudText>
                    @if (dashboardData.RecentTasks.Any())
                    {
                        <MudStack Spacing="2">
                            @foreach (var task in dashboardData.RecentTasks.Take(5))
                            {
                                <MudPaper Class="pa-3" Elevation="0" Style="background: rgba(255,255,255,0.03);">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                        <div>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@task.Title</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@task.ProjectName</MudText>
                                        </div>
                                        <TaskStatusChip Status="@task.Status" />
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <AppEmptyState Title="No recent tasks" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (dashboardData.UpcomingDeadlines.Any())
        {
            <MudPaper Class="glass-card pa-4" Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-4">Upcoming Deadlines</MudText>
                <MudTable Items="dashboardData.UpcomingDeadlines" Hover="true" Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Task</MudTh>
                        <MudTh>Project</MudTh>
                        <MudTh>Assigned To</MudTh>
                        <MudTh>Due Date</MudTh>
                        <MudTh>Priority</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Task">
                            <MudText Typo="Typo.body2" Class="font-weight-bold">@context.Title</MudText>
                        </MudTd>
                        <MudTd DataLabel="Project">@context.ProjectName</MudTd>
                        <MudTd DataLabel="Assigned To">@context.AssignedTo?.FullName</MudTd>
                        <MudTd DataLabel="Due Date">
                            <MudText Typo="Typo.body2" Color="@(IsTaskOverdue(context) ? Color.Error : Color.Default)">
                                @context.DueDate?.ToString("MMM dd, yyyy")
                            </MudText>
                        </MudTd>
                        <MudTd DataLabel="Priority">
                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">@context.Priority</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <TaskStatusChip Status="@context.Status" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private DashboardDto? dashboardData;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        try
        {
            dashboardData = await ApiService.GetDashboardDataAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private static Color GetPriorityColor(string priority) => priority switch
    {
        "Low" => Color.Success,
        "Medium" => Color.Warning,
        "High" => Color.Error,
        "Critical" => Color.Error,
        _ => Color.Default
    };

    private bool IsTaskOverdue(TaskDto task)
    {
        return task.DueDate.HasValue &&
               task.DueDate.Value < DateTime.Today &&
               task.Status != "Completed" &&
               task.Status != "Tested" &&
               task.Status != "Closed";
    }
}
