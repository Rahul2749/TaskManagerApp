@* TaskManager.Client/Pages/Admin/Reports.razor *@
@page "/admin/reports"
@attribute [Authorize(Roles = "OrganizationAdmin")]
@inject IApiService ApiService
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>System Reports</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    <AppPageHeader Title="System Reports"
                   Subtitle="View comprehensive system analytics and reports" />

    @if (isLoading)
    {
        <AppLoading Message="Loading reports..." />
    }
    else if (dashboardData != null)
    {
        <MudGrid Spacing="4" Class="mb-4">
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.TotalProjects.ToString()"
                             Label="Total Projects"
                             Meta="@($"{dashboardData.ActiveProjects} active")"
                             Icon="@Icons.Material.Filled.Folder"
                             IconColor="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.TotalTasks.ToString()"
                             Label="Total Tasks"
                             Meta="@($"{dashboardData.InProgressTasks} in progress")"
                             Icon="@Icons.Material.Filled.TaskAlt"
                             IconColor="Color.Info" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.CompletedTasks.ToString()"
                             Label="Completed Tasks"
                             Meta="@($"{(dashboardData.TotalTasks > 0 ? Math.Round((double)dashboardData.CompletedTasks / dashboardData.TotalTasks * 100, 1) : 0)}% complete")"
                             Icon="@Icons.Material.Filled.CheckCircle"
                             IconColor="Color.Success" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@dashboardData.TotalUsers.ToString()"
                             Label="Total Users"
                             Meta="@($"{dashboardData.ActiveUsers} active")"
                             Icon="@Icons.Material.Filled.People"
                             IconColor="Color.Warning" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="4" Class="mb-4">
            <MudItem xs="12" lg="8">
                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Project Performance</MudText>
                    @if (dashboardData.ProjectSummaries.Any())
                    {
                        <MudTable Items="@dashboardData.ProjectSummaries.OrderByDescending(p => p.CompletionPercentage)"
                                  Hover="true" Dense="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Project</MudTh>
                                <MudTh Style="text-align: center;">Tasks</MudTh>
                                <MudTh Style="text-align: center;">Completed</MudTh>
                                <MudTh Style="text-align: center;">In Progress</MudTh>
                                <MudTh>Completion Rate</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Project">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@context.ProjectName</MudText>
                                </MudTd>
                                <MudTd DataLabel="Tasks" Style="text-align: center;">@context.TotalTasks</MudTd>
                                <MudTd DataLabel="Completed" Style="text-align: center;">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">@context.CompletedTasks</MudChip>
                                </MudTd>
                                <MudTd DataLabel="In Progress" Style="text-align: center;">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.InProgressTasks</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Completion Rate">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudProgressLinear Value="@context.CompletionPercentage" Color="Color.Success" Class="flex-grow-1" />
                                        <MudText Typo="Typo.caption">@context.CompletionPercentage%</MudText>
                                    </MudStack>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <AppEmptyState Title="No project data available" />
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Task Status Distribution</MudText>
                    <MudStack Spacing="3">
                        <div>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                                <MudText Typo="Typo.body2">Completed</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Success">@dashboardData.CompletedTasks</MudText>
                            </MudStack>
                            <MudProgressLinear Value="@GetPercentage(dashboardData.CompletedTasks, dashboardData.TotalTasks)"
                                               Color="Color.Success" />
                        </div>
                        <div>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                                <MudText Typo="Typo.body2">In Progress</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Warning">@dashboardData.InProgressTasks</MudText>
                            </MudStack>
                            <MudProgressLinear Value="@GetPercentage(dashboardData.InProgressTasks, dashboardData.TotalTasks)"
                                               Color="Color.Warning" />
                        </div>
                        <div>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                                <MudText Typo="Typo.body2">Overdue</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Error">@dashboardData.OverdueTasks</MudText>
                            </MudStack>
                            <MudProgressLinear Value="@GetPercentage(dashboardData.OverdueTasks, dashboardData.TotalTasks)"
                                               Color="Color.Error" />
                        </div>
                        <div>
                            @{
                                var otherTasks = dashboardData.TotalTasks - dashboardData.CompletedTasks - dashboardData.InProgressTasks - dashboardData.OverdueTasks;
                            }
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                                <MudText Typo="Typo.body2">Other</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@otherTasks</MudText>
                            </MudStack>
                            <MudProgressLinear Value="@GetPercentage(otherTasks, dashboardData.TotalTasks)"
                                               Color="Color.Default" />
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (dashboardData.UpcomingDeadlines.Any())
        {
            <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-4">Upcoming Deadlines (Next 10)</MudText>
                <MudTable Items="dashboardData.UpcomingDeadlines" Hover="true" Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Task</MudTh>
                        <MudTh>Project</MudTh>
                        <MudTh>Assigned To</MudTh>
                        <MudTh>Due Date</MudTh>
                        <MudTh>Priority</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Task">
                            <MudText Typo="Typo.body2" Class="font-weight-bold">@context.Title</MudText>
                        </MudTd>
                        <MudTd DataLabel="Project">@context.ProjectName</MudTd>
                        <MudTd DataLabel="Assigned To">@context.AssignedTo?.FullName</MudTd>
                        <MudTd DataLabel="Due Date">
                            @if (context.DueDate.HasValue)
                            {
                                var daysUntilDue = (context.DueDate.Value - DateTime.Today).Days;
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.body2" Color="@(daysUntilDue <= 3 ? Color.Error : Color.Default)">
                                        @context.DueDate.Value.ToString("MMM dd, yyyy")
                                    </MudText>
                                    @if (daysUntilDue == 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Today</MudChip>
                                    }
                                    else if (daysUntilDue == 1)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Tomorrow</MudChip>
                                    }
                                </MudStack>
                            }
                        </MudTd>
                        <MudTd DataLabel="Priority">
                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">@context.Priority</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <TaskStatusChip Status="@context.Status" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        <FeatureGate Feature="@FeatureKeys.AdvancedReports">
            <MudPaper Class="glass-card pa-4" Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-2">Advanced analytics</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Export reports to CSV/PDF, schedule email digests, and build custom dashboards.
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download">
                    Export full report
                </MudButton>
            </MudPaper>
        </FeatureGate>
    }
</MudContainer>

@code {
    private DashboardDto? dashboardData;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadReportData();
    }

    private async Task LoadReportData()
    {
        isLoading = true;
        try
        {
            dashboardData = await ApiService.GetDashboardDataAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading reports: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private double GetPercentage(int value, int total)
    {
        return total > 0 ? Math.Round((double)value / total * 100, 1) : 0;
    }

    private static Color GetPriorityColor(string priority) => priority switch
    {
        "Low" => Color.Success,
        "Medium" => Color.Warning,
        "High" => Color.Error,
        "Critical" => Color.Error,
        _ => Color.Default
    };
}
