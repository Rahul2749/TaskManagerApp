@* Client/Pages/Manager/Dashboard.razor *@
@page "/manager/dashboard"
@using TaskManager.Shared.DTOs
@inject IApiService ApiService
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Manager Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    @if (isLoading)
    {
        <AppLoading Message="Loading tasks..." />
    }
    else
    {
        <MudGrid Spacing="4" Class="mb-4">
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@((todoTasks.Count + inProgressTasks.Count + completedTasks.Count).ToString())"
                             Label="Total Tasks"
                             Icon="@Icons.Material.Filled.TaskAlt"
                             IconColor="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@inProgressTasks.Count.ToString()"
                             Label="In Progress"
                             Icon="@Icons.Material.Filled.HourglassTop"
                             IconColor="Color.Warning" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@completedTasks.Count.ToString()"
                             Label="Completed"
                             Icon="@Icons.Material.Filled.CheckCircle"
                             IconColor="Color.Success" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3">
                <AppStatCard Value="@todoTasks.Count.ToString()"
                             Label="To Do"
                             Icon="@Icons.Material.Filled.PendingActions"
                             IconColor="Color.Error" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="4" Class="mb-4">
            <MudItem xs="12" md="4">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="min-height: 500px;">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.overline" Color="Color.Secondary">To Do</MudText>
                        <MudChip T="string" Size="Size.Small">@todoTasks.Count</MudChip>
                    </MudStack>
                    <MudStack Spacing="2">
                        @foreach (var task in todoTasks)
                        {
                            <MudPaper Class="pa-3 task-card" Elevation="0" Style="cursor: pointer; background: rgba(255,255,255,0.03);"
                                      @onclick="() => OpenTaskDetails(task)">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        @(task.AssignedTo?.FirstName?.Substring(0, 1) ?? "?")
                                    </MudAvatar>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @(task.AssignedTo?.FullName ?? "Unassigned")
                                    </MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">ID: @task.Id?.ToString("D8")</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold mt-1">@task.Title</MudText>
                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@task.Description</MudText>
                                }
                            </MudPaper>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="min-height: 500px;">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.overline" Color="Color.Secondary">In Progress</MudText>
                        <MudChip T="string" Size="Size.Small">@inProgressTasks.Count</MudChip>
                    </MudStack>
                    <MudStack Spacing="2">
                        @foreach (var task in inProgressTasks)
                        {
                            <MudPaper Class="pa-3 task-card" Elevation="0" Style="cursor: pointer; background: rgba(255,255,255,0.03);"
                                      @onclick="() => OpenTaskDetails(task)">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        @(task.AssignedTo?.FirstName?.Substring(0, 1) ?? "?")
                                    </MudAvatar>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @(task.AssignedTo?.FullName ?? "Unassigned")
                                    </MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">ID: @task.Id?.ToString("D8")</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold mt-1">@task.Title</MudText>
                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@task.Description</MudText>
                                }
                                @if (task.EstimatedHours.HasValue && task.EstimatedHours > 0)
                                {
                                    <MudProgressLinear Value="@GetProgressPercentage(task)" Color="Color.Primary" Class="mt-2" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @task.ActualHours / @task.EstimatedHours hrs
                                    </MudText>
                                }
                            </MudPaper>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="min-height: 500px;">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.overline" Color="Color.Secondary">Completed</MudText>
                        <MudChip T="string" Size="Size.Small">@completedTasks.Count</MudChip>
                    </MudStack>
                    <MudStack Spacing="2">
                        @foreach (var task in completedTasks)
                        {
                            <MudPaper Class="pa-3 task-card" Elevation="0"
                                      Style="cursor: pointer; background: rgba(255,255,255,0.03); opacity: 0.7;"
                                      @onclick="() => OpenTaskDetails(task)">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        @(task.AssignedTo?.FirstName?.Substring(0, 1) ?? "?")
                                    </MudAvatar>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @(task.AssignedTo?.FullName ?? "Unassigned")
                                    </MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">ID: @task.Id?.ToString("D8")</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold mt-1">@task.Title</MudText>
                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@task.Description</MudText>
                                }
                            </MudPaper>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Justify="Justify.FlexEnd" Class="gap-3 flex-wrap">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.PersonAdd">
                Assign Task
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.RateReview">
                Submit Review
            </MudButton>
        </MudStack>
    }
</MudContainer>

@code {
    private bool isLoading = true;
    private List<TaskDto> todoTasks = new();
    private List<TaskDto> inProgressTasks = new();
    private List<TaskDto> completedTasks = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        isLoading = true;
        try
        {
            var allTasks = await ApiService.GetTasksAsync() ?? new();

            todoTasks = allTasks.Where(t => t.Status == "NotAssigned" || t.Status == "Assigned").ToList();
            inProgressTasks = allTasks.Where(t => t.Status == "InProgress").ToList();
            completedTasks = allTasks.Where(t => t.Status == "Completed" || t.Status == "Tested" || t.Status == "Closed").ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tasks: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private double GetProgressPercentage(TaskDto task)
    {
        if (task.EstimatedHours.HasValue && task.EstimatedHours > 0)
        {
            return Math.Min((double)task.ActualHours / (double)task.EstimatedHours * 100, 100);
        }
        return 0;
    }

    private void OpenTaskDetails(TaskDto task)
    {
        Console.WriteLine($"Opening task: {task.Title}");
    }
}
