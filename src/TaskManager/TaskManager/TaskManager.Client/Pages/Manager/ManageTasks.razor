@* TaskManager.Client/Pages/Manager/ManageTasks.razor *@
@page "/manager/tasks"
@attribute [Authorize(Roles = "Manager")]
@inject IApiService ApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Manage Tasks</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    <AppPageHeader Title="Manage Tasks" Subtitle="Create and assign tasks to your team">
        <Actions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                New Task
            </MudButton>
        </Actions>
    </AppPageHeader>

    <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4">
                <MudSelect T="int?" Value="filterProjectId" ValueChanged="OnProjectFilterChanged" Label="Project" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var project in projects)
                    {
                        <MudSelectItem T="int?" Value="@project.Id">@project.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="string" Value="filterStatus" ValueChanged="OnStatusFilterChanged" Label="Status" Variant="Variant.Outlined" Clearable="true">
                    <MudSelectItem Value="@("NotAssigned")">Not Assigned</MudSelectItem>
                    <MudSelectItem Value="@("Assigned")">Assigned</MudSelectItem>
                    <MudSelectItem Value="@("InProgress")">In Progress</MudSelectItem>
                    <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                    <MudSelectItem Value="@("Tested")">Tested</MudSelectItem>
                    <MudSelectItem Value="@("Closed")">Closed</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="int?" Value="filterAssignedToId" ValueChanged="OnAssignedToFilterChanged" Label="Assigned To" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var user in users)
                    {
                        <MudSelectItem T="int?" Value="@user.Id">@user.FullName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (isLoading)
    {
        <AppLoading Message="Loading tasks..." />
    }
    else if (!tasks.Any())
    {
        <AppEmptyState Title="No tasks found" Description="Create your first task to get started.">
            <Actions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                    New Task
                </MudButton>
            </Actions>
        </AppEmptyState>
    }
    else
    {
        <MudPaper Class="glass-card pa-0" Elevation="0">
            <MudTable Items="tasks" Hover="true" Dense="true" Elevation="0" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Task</MudTh>
                    <MudTh>Project</MudTh>
                    <MudTh>Assigned To</MudTh>
                    <MudTh>Priority</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Due Date</MudTh>
                    <MudTh>Hours</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Task">
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Title</MudText>
                    </MudTd>
                    <MudTd DataLabel="Project">@context.ProjectName</MudTd>
                    <MudTd DataLabel="Assigned To">@(context.AssignedTo?.FullName ?? "Unassigned")</MudTd>
                    <MudTd DataLabel="Priority">
                        <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">@context.Priority</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <TaskStatusChip Status="@context.Status" />
                    </MudTd>
                    <MudTd DataLabel="Due Date">
                        @if (context.DueDate.HasValue)
                        {
                            var isOverdue = context.DueDate.Value < DateTime.Today &&
                                context.Status is not ("Completed" or "Tested" or "Closed");
                            <MudText Typo="Typo.body2" Color="@(isOverdue ? Color.Error : Color.Default)">
                                @context.DueDate.Value.ToString("MMM dd, yyyy")
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Hours">
                        <MudText Typo="Typo.caption">@context.ActualHours / @(context.EstimatedHours?.ToString() ?? "-") hrs</MudText>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteTask(context.Id!.Value))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

<MudDialog @bind-Visible="showDialog" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(isEditMode ? "Edit Task" : "Create Task")</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="taskModel" OnValidSubmit="SaveTask">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@errorMessage</MudAlert>
            }

            <MudTextField @bind-Value="taskModel.Title"
                          Label="Task Title"
                          Variant="Variant.Outlined"
                          Placeholder="Enter task title"
                          Class="mb-4"
                          For="@(() => taskModel.Title)" />

            <MudTextField @bind-Value="taskModel.Description"
                          Label="Description"
                          Variant="Variant.Outlined"
                          Lines="3"
                          Placeholder="Enter task description"
                          Class="mb-4" />

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="int" Value="taskModel.ProjectId" ValueChanged="OnProjectChange" Label="Project" Variant="Variant.Outlined">
                        <MudSelectItem Value="0">Select Project</MudSelectItem>
                        @foreach (var project in projects)
                        {
                            <MudSelectItem Value="@project.Id">@project.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" @bind-Value="taskModel.AssignedToId" Label="Assign To" Variant="Variant.Outlined" Clearable="true">
                        <MudSelectItem T="int?" Value="@((int?)null)">Unassigned</MudSelectItem>
                        @foreach (var user in availableUsers)
                        {
                            <MudSelectItem T="int?" Value="@user.Id">@user.FullName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="taskModel.Priority" Label="Priority" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                        <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                        <MudSelectItem Value="@("High")">High</MudSelectItem>
                        <MudSelectItem Value="@("Critical")">Critical</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="taskModel.Status" Label="Status" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("NotAssigned")">Not Assigned</MudSelectItem>
                        <MudSelectItem Value="@("Assigned")">Assigned</MudSelectItem>
                        <MudSelectItem Value="@("InProgress")">In Progress</MudSelectItem>
                        <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                        <MudSelectItem Value="@("Tested")">Tested</MudSelectItem>
                        <MudSelectItem Value="@("Closed")">Closed</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="taskModel.EstimatedHours" Label="Estimated Hours" Variant="Variant.Outlined" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="taskModel.StartDate" Label="Start Date" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="taskModel.DueDate" Label="Due Date" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="isSaving" OnClick="SaveTask">
            @if (isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(isEditMode ? "Update Task" : "Create Task")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<TaskDto> tasks = new();
    private List<ProjectDto> projects = new();
    private List<UserDto> users = new();
    private List<UserDto> availableUsers = new();

    private bool isLoading = true;
    private bool showDialog = false;
    private bool isEditMode = false;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private TaskDto taskModel = new();

    private int? filterProjectId = null;
    private string? filterStatus = null;
    private int? filterAssignedToId = null;

    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var projectsTask = ApiService.GetProjectsAsync();
            var usersTask = ApiService.GetUsersAsync("User");
            var tasksTask = ApiService.GetTasksAsync(filterProjectId, filterStatus, filterAssignedToId);

            await Task.WhenAll(projectsTask, usersTask, tasksTask);

            projects = await projectsTask ?? new();
            users = await usersTask ?? new();
            tasks = await tasksTask ?? new();
            availableUsers = users;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnProjectFilterChanged(int? value)
    {
        filterProjectId = value;
        await LoadData();
    }

    private async Task OnStatusFilterChanged(string? value)
    {
        filterStatus = value;
        await LoadData();
    }

    private async Task OnAssignedToFilterChanged(int? value)
    {
        filterAssignedToId = value;
        await LoadData();
    }

    private void OpenCreateDialog()
    {
        isEditMode = false;
        taskModel = new TaskDto { Priority = "Medium", Status = "NotAssigned" };
        errorMessage = string.Empty;
        showDialog = true;
    }

    private void OpenEditDialog(TaskDto task)
    {
        isEditMode = true;
        taskModel = new TaskDto
        {
            Id = task.Id,
            Title = task.Title,
            Description = task.Description,
            ProjectId = task.ProjectId,
            AssignedToId = task.AssignedToId,
            Priority = task.Priority,
            Status = task.Status,
            EstimatedHours = task.EstimatedHours,
            StartDate = task.StartDate,
            DueDate = task.DueDate
        };
        _ = LoadProjectUsers(task.ProjectId);
        errorMessage = string.Empty;
        showDialog = true;
    }

    private async Task OnProjectChange(int projectId)
    {
        taskModel.ProjectId = projectId;
        if (projectId > 0)
            await LoadProjectUsers(projectId);
        else
            availableUsers = new();
    }

    private async Task LoadProjectUsers(int projectId)
    {
        try
        {
            availableUsers = await ApiService.GetProjectUsersAsync(projectId) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading project users: {ex.Message}");
            availableUsers = new();
        }
    }

    private void CloseDialog()
    {
        showDialog = false;
        taskModel = new();
        availableUsers = new();
        errorMessage = string.Empty;
    }

    private async Task SaveTask()
    {
        if (!ValidateTaskModel()) return;

        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            TaskDto? result;

            if (isEditMode && taskModel.Id.HasValue)
                result = await ApiService.UpdateTaskAsync(taskModel.Id.Value, taskModel);
            else
                result = await ApiService.CreateTaskAsync(taskModel);

            if (result != null)
            {
                await LoadData();
                CloseDialog();
                Snackbar.Add(isEditMode ? "Task updated." : "Task created.", Severity.Success);
            }
            else
            {
                errorMessage = "Failed to save task. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteTask(int taskId)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete Task",
            "Are you sure you want to delete this task?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            var success = await ApiService.DeleteTaskAsync(taskId);
            if (success)
            {
                await LoadData();
                Snackbar.Add("Task deleted.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting task: {ex.Message}", Severity.Error);
        }
    }

    private bool ValidateTaskModel()
    {
        if (string.IsNullOrWhiteSpace(taskModel.Title))
        {
            errorMessage = "Task title is required.";
            return false;
        }

        if (taskModel.ProjectId <= 0)
        {
            errorMessage = "Please select a project.";
            return false;
        }

        return true;
    }

    private static Color GetPriorityColor(string priority) => priority switch
    {
        "Low" => Color.Success,
        "Medium" => Color.Info,
        "High" => Color.Warning,
        "Critical" => Color.Error,
        _ => Color.Default
    };
}
