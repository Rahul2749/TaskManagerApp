@* TaskManager.Client/Pages/Manager/ManageUsers.razor *@
@page "/manager/users"
@attribute [Authorize(Roles = "Manager")]
@inject IApiService ApiService
@inject IJSRuntime JSRuntime
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Manage Users</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-2">
    <AppPageHeader Title="Manage Users" Subtitle="Create and manage user accounts">
        <Actions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                New User
            </MudButton>
        </Actions>
    </AppPageHeader>

    @if (isLoading)
    {
        <AppLoading Message="Loading users..." />
    }
    else if (!users.Any())
    {
        <AppEmptyState Title="No users found" Description="Create your first user!" />
    }
    else
    {
        <MudPaper Class="glass-card pa-0" Elevation="0">
            <MudTable Items="users" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Username</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Created Date</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Small" Color="Color.Primary">@(context.FirstName?.Substring(0, 1))</MudAvatar>
                            <MudText>@context.FullName</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Username">@context.Username</MudTd>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                            @(context.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Created Date">@context.CreatedAt.ToString("MMM dd, yyyy")</MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" title="Edit" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteUser(context.Id))" title="Delete" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

<MudDialog Visible="showDialog" VisibleChanged="OnDialogVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(isEditMode ? "Edit User" : "Create User")</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="userModel" OnValidSubmit="SaveUser">
            <DataAnnotationsValidator />
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@errorMessage</MudAlert>
            }

            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="userModel.FirstName" Label="First Name" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Enter first name" />
                    <ValidationMessage For="@(() => userModel.FirstName)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="userModel.LastName" Label="Last Name" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Enter last name" />
                    <ValidationMessage For="@(() => userModel.LastName)" />
                </MudItem>
            </MudGrid>

            <MudTextField @bind-Value="userModel.Username" Label="Username" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Placeholder="Enter username" />
            <ValidationMessage For="@(() => userModel.Username)" />

            <MudTextField @bind-Value="userModel.Email" Label="Email" InputType="InputType.Email" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Placeholder="Enter email address" />
            <ValidationMessage For="@(() => userModel.Email)" />

            <MudTextField @bind-Value="userModel.Password"
                          Label="@($"Password {(isEditMode ? "(leave blank to keep current)" : "")}")"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mt-2"
                          Placeholder="Enter password" />
            <ValidationMessage For="@(() => userModel.Password)" />

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                <MudButton OnClick="CloseDialog">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="isSaving">
                    @if (isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @(isEditMode ? "Update User" : "Create User")
                </MudButton>
            </MudStack>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    private List<UserDto> users = new();
    private bool isLoading = true;
    private bool showDialog = false;
    private bool isEditMode = false;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private RegisterDto userModel = new();
    private int editingUserId = 0;

    private readonly DialogOptions _dialogOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        try
        {
            users = await ApiService.GetUsersAsync("User") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        isEditMode = false;
        userModel = new RegisterDto { Role = "User" };
        errorMessage = string.Empty;
        showDialog = true;
    }

    private void OpenEditDialog(UserDto user)
    {
        isEditMode = true;
        editingUserId = user.Id;
        userModel = new RegisterDto
        {
            Username = user.Username,
            Email = user.Email,
            FirstName = user.FirstName,
            LastName = user.LastName,
            Role = "User",
            Password = string.Empty
        };
        errorMessage = string.Empty;
        showDialog = true;
    }

    private void HandleBackdropClick()
    {
        CloseDialog();
    }

    private void CloseDialog()
    {
        showDialog = false;
        userModel = new();
        errorMessage = string.Empty;
        StateHasChanged();
    }

    private void OnDialogVisibleChanged(bool visible)
    {
        if (visible)
            showDialog = true;
        else if (showDialog)
            HandleBackdropClick();
    }

    private async Task SaveUser()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            UserDto? result;

            if (isEditMode)
            {
                result = await ApiService.UpdateUserAsync(editingUserId, userModel);
            }
            else
            {
                result = await ApiService.CreateUserAsync(userModel);
            }

            if (result != null)
            {
                await LoadUsers();
                CloseDialog();
            }
            else
            {
                errorMessage = "Failed to save user. Username or email may already exist.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteUser(int userId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this user?"))
        {
            try
            {
                var success = await ApiService.DeleteUserAsync(userId);
                if (success)
                {
                    await LoadUsers();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting user: {ex.Message}");
            }
        }
    }
}
