@* TaskManager.Client/Pages/Manager/ProjectUserMapping.razor *@
@page "/manager/project-users"
@attribute [Authorize(Roles = "Manager")]
@inject IApiService ApiService
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Project User Mapping</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-2">
    <AppPageHeader Title="Project User Mapping" Subtitle="Assign users to projects" />

    @if (isLoading)
    {
        <AppLoading Message="Loading data..." />
    }
    else
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Assign Users to Project</MudText>

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <MudAlert Severity="Severity.Success" Class="mb-4" Dense="true" ShowCloseIcon="true" CloseIconClicked="@(() => successMessage = string.Empty)">
                            @successMessage
                        </MudAlert>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" ShowCloseIcon="true" CloseIconClicked="@(() => errorMessage = string.Empty)">
                            @errorMessage
                        </MudAlert>
                    }

                    <MudSelect T="int?"
                               Value="selectedProjectId"
                               ValueChanged="OnProjectSelectedFromMud"
                               Label="Select Project"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               Placeholder="-- Select a Project --">
                        @foreach (var project in projects)
                        {
                            <MudSelectItem T="int?" Value="@project.Id">@project.Name</MudSelectItem>
                        }
                    </MudSelect>

                    @if (selectedProjectId.HasValue)
                    {
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-6 mb-2">
                            <MudText Typo="Typo.subtitle2">Available Users</MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SelectAll">Select All</MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="DeselectAll">Deselect All</MudButton>
                            </MudStack>
                        </MudStack>

                        @if (availableUsers.Any())
                        {
                            <MudStack Spacing="1" Class="mb-4">
                                @foreach (var user in availableUsers)
                                {
                                    <MudCheckBox T="bool"
                                                 Value="@IsUserSelected(user.Id)"
                                                 ValueChanged="@((bool v) => ToggleUser(user.Id, v))"
                                                 Color="Color.Primary"
                                                 Dense="true">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudAvatar Size="Size.Small" Color="Color.Primary">@(user.FirstName?.Substring(0, 1))</MudAvatar>
                                            <div>
                                                <MudText Typo="Typo.body2">@user.FullName</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@user.Email</MudText>
                                            </div>
                                        </MudStack>
                                    </MudCheckBox>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <AppEmptyState Title="No users available" />
                        }

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="SaveMapping"
                                   Disabled="isSaving">
                            @if (isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Save Assignment
                        </MudButton>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-4" Elevation="0">
                    <MudText Typo="Typo.h6" Class="mb-4">Projects Overview</MudText>

                    @if (projects.Any())
                    {
                        <MudStack Spacing="3">
                            @foreach (var project in projects)
                            {
                                <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-2">
                                        <div>
                                            <MudText Typo="Typo.subtitle1">@project.Name</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @project.AssignedUsers.Count users assigned
                                            </MudText>
                                        </div>
                                        <MudChip T="string" Size="Size.Small" Color="@GetProjectStatusColor(project.Status)">@project.Status</MudChip>
                                    </MudStack>

                                    @if (project.AssignedUsers.Any())
                                    {
                                        <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                                            @foreach (var user in project.AssignedUsers.Take(4))
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                    <MudAvatar Size="Size.Small" Class="mr-1">@(user.FirstName?.Substring(0, 1))</MudAvatar>
                                                    @user.FullName
                                                </MudChip>
                                            }
                                            @if (project.AssignedUsers.Count > 4)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                                    +@(project.AssignedUsers.Count - 4) more
                                                </MudChip>
                                            }
                                        </MudStack>
                                    }
                                </MudPaper>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <AppEmptyState Title="No projects found" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private List<ProjectDto> projects = new();
    private List<UserDto> availableUsers = new();
    private HashSet<int> selectedUserIds = new();

    private int? selectedProjectId = null;
    private bool isLoading = true;
    private bool isSaving = false;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var projectsTask = ApiService.GetProjectsAsync();
            var usersTask = ApiService.GetUsersAsync("User");

            await Task.WhenAll(projectsTask, usersTask);

            projects = await projectsTask ?? new();
            availableUsers = await usersTask ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            errorMessage = "Failed to load data. Please refresh the page.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task OnProjectSelectedFromMud(int? projectId)
    {
        return OnProjectSelected(new ChangeEventArgs { Value = projectId?.ToString() ?? string.Empty });
    }

    private async Task OnProjectSelected(ChangeEventArgs e)
    {
        successMessage = string.Empty;
        errorMessage = string.Empty;

        if (string.IsNullOrEmpty(e.Value?.ToString()))
        {
            selectedProjectId = null;
            selectedUserIds.Clear();
            return;
        }

        selectedProjectId = int.Parse(e.Value.ToString()!);

        try
        {
            var project = projects.FirstOrDefault(p => p.Id == selectedProjectId);
            if (project != null)
            {
                selectedUserIds = project.AssignedUsers.Select(u => u.Id).ToHashSet();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error selecting project: {ex.Message}");
            errorMessage = "Failed to load project users.";
        }
    }

    private void ToggleUser(int userId, bool isChecked)
    {
        if (isChecked)
        {
            selectedUserIds.Add(userId);
        }
        else
        {
            selectedUserIds.Remove(userId);
        }
    }

    private bool IsUserSelected(int userId)
    {
        return selectedUserIds.Contains(userId);
    }

    private void SelectAll()
    {
        selectedUserIds = availableUsers.Select(u => u.Id).ToHashSet();
    }

    private void DeselectAll()
    {
        selectedUserIds.Clear();
    }

    private async Task SaveMapping()
    {
        if (!selectedProjectId.HasValue)
        {
            errorMessage = "Please select a project first.";
            return;
        }

        isSaving = true;
        successMessage = string.Empty;
        errorMessage = string.Empty;

        try
        {
            var success = await ApiService.AssignUsersToProjectAsync(
                selectedProjectId.Value,
                selectedUserIds.ToList()
            );

            if (success)
            {
                successMessage = "Users assigned successfully!";
                await LoadData();
            }
            else
            {
                errorMessage = "Failed to assign users. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetProjectStatusClass(string status)
    {
        return status switch
        {
            "Active" => "bg-success",
            "OnHold" => "bg-warning",
            "Completed" => "bg-primary",
            "Cancelled" => "bg-secondary",
            _ => "bg-secondary"
        };
    }

    private Color GetProjectStatusColor(string status)
    {
        return status switch
        {
            "Active" => Color.Success,
            "OnHold" => Color.Warning,
            "Completed" => Color.Primary,
            "Cancelled" => Color.Default,
            _ => Color.Default
        };
    }
}
