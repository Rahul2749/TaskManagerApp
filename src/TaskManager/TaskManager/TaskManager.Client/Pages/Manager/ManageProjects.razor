@* TaskManager.Client/Pages/Manager/ManageProjects.razor *@
@page "/manager/projects"
@attribute [Authorize(Roles = "Manager")]
@inject IApiService ApiService
@inject IJSRuntime JSRuntime
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Manage Projects</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-2">
    <AppPageHeader Title="Manage Projects" Subtitle="Create and manage your projects">
        <Actions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                New Project
            </MudButton>
        </Actions>
    </AppPageHeader>

    @if (isLoading)
    {
        <AppLoading Message="Loading projects..." />
    }
    else if (!projects.Any())
    {
        <AppEmptyState Title="No Projects Found" Description="Create your first project to get started!">
            <Actions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                    Create Project
                </MudButton>
            </Actions>
        </AppEmptyState>
    }
    else
    {
        <MudGrid Spacing="4">
            @foreach (var project in projects)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Class="glass-card" Elevation="0">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@project.Name</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudChip T="string" Size="Size.Small" Color="@GetProjectStatusColor(project.Status)">@project.Status</MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>

                        <MudCardContent>
                            @if (!string.IsNullOrEmpty(project.Description))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                    @(project.Description.Length > 120 ? project.Description.Substring(0, 120) + "..." : project.Description)
                                </MudText>
                            }

                            <div class="mb-4">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Progress</MudText>
                                    <MudText Typo="Typo.caption">@project.CompletedTaskCount / @project.TaskCount tasks</MudText>
                                </MudStack>
                                <MudProgressLinear Color="Color.Primary" Value="@GetCompletionPercentage(project)" Rounded="true" Size="Size.Small" />
                            </div>

                            <MudGrid Spacing="2" Class="mb-4">
                                <MudItem xs="6">
                                    <AppStatCard Value="@project.TaskCount.ToString()" Label="Tasks" Emoji="✅" IconColor="Color.Success" />
                                </MudItem>
                                <MudItem xs="6">
                                    <AppStatCard Value="@project.AssignedUsers.Count.ToString()" Label="Members" Emoji="👥" IconColor="Color.Info" />
                                </MudItem>
                            </MudGrid>

                            @if (project.StartDate.HasValue || project.EndDate.HasValue)
                            {
                                <MudStack Spacing="1" Class="mb-2">
                                    @if (project.StartDate.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Start: @project.StartDate.Value.ToString("MMM dd, yyyy")
                                        </MudText>
                                    }
                                    @if (project.EndDate.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            End: @project.EndDate.Value.ToString("MMM dd, yyyy")
                                        </MudText>
                                    }
                                </MudStack>
                            }
                        </MudCardContent>

                        <MudCardActions>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => OpenEditDialog(project))">Edit</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => DeleteProject(project.Id!.Value))">Delete</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<MudDialog Visible="showDialog" VisibleChanged="OnDialogVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(isEditMode ? "Edit Project" : "Create Project")</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="projectModel" OnValidSubmit="SaveProject">
            <DataAnnotationsValidator />
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@errorMessage</MudAlert>
            }

            <MudGrid Spacing="2">
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="projectModel.Name" Label="Project Name" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Enter project name" />
                    <ValidationMessage For="@(() => projectModel.Name)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect @bind-Value="projectModel.Status" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                        <MudSelectItem Value="@("OnHold")">On Hold</MudSelectItem>
                        <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                        <MudSelectItem Value="@("Cancelled")">Cancelled</MudSelectItem>
                    </MudSelect>
                    <ValidationMessage For="@(() => projectModel.Status)" />
                </MudItem>
            </MudGrid>

            <MudTextField @bind-Value="projectModel.Description"
                          Label="Description"
                          Lines="4"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mt-2"
                          Placeholder="Enter project description" />

            <MudGrid Spacing="2" Class="mt-2">
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="projectModel.StartDate" Label="Start Date" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="projectModel.EndDate" Label="End Date" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                <MudButton OnClick="CloseDialog">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="isSaving">
                    @if (isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @(isEditMode ? "Update Project" : "Create Project")
                </MudButton>
            </MudStack>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    private List<ProjectDto> projects = new();
    private bool isLoading = true;
    private bool showDialog = false;
    private bool isEditMode = false;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private ProjectDto projectModel = new();

    private readonly DialogOptions _dialogOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        isLoading = true;
        try
        {
            projects = await ApiService.GetProjectsAsync() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading projects: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        isEditMode = false;
        projectModel = new ProjectDto { Status = "Active" };
        errorMessage = string.Empty;
        showDialog = true;
    }

    private void OpenEditDialog(ProjectDto project)
    {
        isEditMode = true;
        projectModel = new ProjectDto
        {
            Id = project.Id,
            Name = project.Name,
            Description = project.Description,
            StartDate = project.StartDate,
            EndDate = project.EndDate,
            Status = project.Status
        };
        errorMessage = string.Empty;
        showDialog = true;
    }

    private void CloseDialog()
    {
        showDialog = false;
        projectModel = new();
        errorMessage = string.Empty;
        StateHasChanged();
    }

    private void HandleBackdropClick()
    {
        CloseDialog();
    }

    private void OnDialogVisibleChanged(bool visible)
    {
        if (visible)
            showDialog = true;
        else if (showDialog)
            HandleBackdropClick();
    }

    private async Task SaveProject()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            ProjectDto? result;

            if (isEditMode && projectModel.Id.HasValue)
            {
                result = await ApiService.UpdateProjectAsync(projectModel.Id.Value, projectModel);
            }
            else
            {
                result = await ApiService.CreateProjectAsync(projectModel);
            }

            if (result != null)
            {
                await LoadProjects();
                CloseDialog();
            }
            else
            {
                errorMessage = "Failed to save project. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteProject(int projectId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this project? All tasks will be deleted."))
        {
            try
            {
                var success = await ApiService.DeleteProjectAsync(projectId);
                if (success)
                {
                    await LoadProjects();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting project: {ex.Message}");
            }
        }
    }

    private string GetProjectStatusClass(string status)
    {
        return status switch
        {
            "Active" => "bg-success",
            "OnHold" => "bg-warning",
            "Completed" => "bg-primary",
            "Cancelled" => "bg-secondary",
            _ => "bg-secondary"
        };
    }

    private Color GetProjectStatusColor(string status)
    {
        return status switch
        {
            "Active" => Color.Success,
            "OnHold" => Color.Warning,
            "Completed" => Color.Primary,
            "Cancelled" => Color.Default,
            _ => Color.Default
        };
    }

    private double GetCompletionPercentage(ProjectDto project)
    {
        return project.TaskCount > 0
            ? Math.Round((double)project.CompletedTaskCount / project.TaskCount * 100, 1)
            : 0;
    }
}
