@* Components/Pages/Login.razor *@
@page "/login"
@layout TaskManager.Client.Components.Layout.LoginLayout
@using TaskManager.Client.Components
@using TaskManager.Client.Components.Layout
@using TaskManager.Shared.DTOs
@using TaskManager.Client.Services
@inject IAuthServiceClient AuthService
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="login-split-layout">
    <div class="login-visuals">
        <div class="visuals-content">
            <div class="brand-logo-light">
                <i class="ph ph-clipboard-text brand-icon"></i>
                <span class="brand-text">TaskManager</span>
            </div>

            <h1 class="visuals-headline">
                Organize your work.<br />
                <span class="highlight-text">Find your focus.</span>
            </h1>

            <p class="visuals-subheadline">
                The soft modern workspace for teams that value clarity and calm over chaos.
            </p>

            <div class="abstract-shapes">
                <div class="shape shape-1"></div>
                <div class="shape shape-2"></div>
                <div class="shape shape-3"></div>
            </div>
        </div>
    </div>

    <div class="login-form-side">
        <div class="login-form-container">
            <div class="mobile-brand">
                <i class="ph ph-clipboard-text brand-icon"></i>
                <span class="brand-text">TaskManager</span>
            </div>

            <MudText Typo="Typo.h4" Class="mb-1">Welcome back</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
                Please enter your details to sign in.
            </MudText>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@errorMessage</MudAlert>
            }

            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="loginModel.Username"
                              Label="Username"
                              Variant="Variant.Outlined"
                              Placeholder="Enter your username"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Class="mb-4"
                              For="@(() => loginModel.Username)"
                              autocomplete="username" />

                <MudTextField @bind-Value="loginModel.Password"
                              Label="Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Placeholder="••••••••"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Lock"
                              Class="mb-4"
                              For="@(() => loginModel.Password)"
                              autocomplete="current-password" />

                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                    <MudCheckBox @bind-Value="rememberMe" Label="Remember me" Color="Color.Primary" />
                    <MudLink Href="/forgot-password" Typo="Typo.body2">Forgot password?</MudLink>
                </MudStack>

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="isLoading"
                           EndIcon="@Icons.Material.Filled.ArrowForward">
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Signing in...</span>
                    }
                    else
                    {
                        <span>Sign in to workspace</span>
                    }
                </MudButton>
            </EditForm>

            <MudDivider Class="my-6" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">Sign in with SSO</MudText>
            <MudStack Row="true" Spacing="2" Class="mb-2">
                <MudTextField @bind-Value="_ssoSlug" Label="Workspace slug" Variant="Variant.Outlined" Dense="true"
                              HelperText="From your workspace URL / settings" Style="flex:1" />
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="StartSso"
                           Style="height: 40px; margin-top: 4px;">Continue</MudButton>
            </MudStack>

            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-6">
                Don't have an account?
                <MudLink Href="/register" Typo="Typo.body2">Sign up for free</MudLink>
            </MudText>
        </div>
    </div>
</div>

<style>
    .login-split-layout {
        display: flex;
        min-height: 100vh;
        width: 100%;
        background-color: var(--bg-main);
    }

    .login-visuals {
        flex: 1;
        background: linear-gradient(135deg, var(--bg-sidebar), var(--bg-main));
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem;
        border-right: 1px solid var(--border-color);
    }

    .visuals-content {
        position: relative;
        z-index: 2;
        max-width: 600px;
    }

    .brand-logo-light {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 4rem;
        color: var(--primary-navy);
    }

    .brand-icon {
        font-size: 2.5rem;
        color: var(--accent-purple);
    }

    .brand-text {
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .visuals-headline {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.1;
        color: var(--primary-navy);
        margin-bottom: 1.5rem;
        letter-spacing: -0.02em;
    }

    .highlight-text {
        color: var(--accent-purple);
    }

    .visuals-subheadline {
        font-size: 1.25rem;
        color: var(--text-secondary);
        line-height: 1.6;
        max-width: 480px;
    }

    .abstract-shapes {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1;
        pointer-events: none;
    }

    .shape {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.5;
        animation: float 20s infinite ease-in-out;
    }

    .shape-1 {
        background: var(--accent-purple);
        width: 400px;
        height: 400px;
        top: -100px;
        right: -100px;
    }

    .shape-2 {
        background: var(--accent-calm);
        width: 500px;
        height: 500px;
        bottom: -200px;
        left: -100px;
        animation-delay: 2s;
    }

    .shape-3 {
        background: var(--accent-warm);
        width: 300px;
        height: 300px;
        top: 40%;
        right: 10%;
        animation-delay: 5s;
    }

    @@keyframes float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(30px, -50px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
    }

    .login-form-side {
        width: 100%;
        max-width: 600px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-card);
        position: relative;
    }

    .login-form-container {
        width: 100%;
        max-width: 420px;
        padding: 2.5rem;
    }

    .mobile-brand {
        display: none;
        align-items: center;
        gap: 10px;
        margin-bottom: 3rem;
        color: var(--primary-navy);
        justify-content: center;
    }

    @@media (max-width: 900px) {
        .login-visuals { display: none; }
        .login-form-side { max-width: 100%; background: var(--bg-main); }
        .login-form-container {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-card);
            padding: 3rem 2rem;
            margin: 2rem;
        }
        .mobile-brand { display: flex; }
        .brand-icon { font-size: 2rem; }
        .brand-text { font-size: 1.5rem; }
    }

    @@media (max-width: 480px) {
        .login-form-container { padding: 2rem 1.5rem; margin: 1rem; }
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "ssoError")]
    public string? SsoError { get; set; }

    private LoginDto loginModel = new();
    private bool isLoading = false;
    private bool rememberMe = false;
    private string errorMessage = string.Empty;
    private string _ssoSlug = "";

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(SsoError))
            errorMessage = Uri.UnescapeDataString(SsoError);
    }

    private void StartSso()
    {
        if (string.IsNullOrWhiteSpace(_ssoSlug))
        {
            errorMessage = "Enter your workspace slug to continue with SSO.";
            return;
        }

        var slug = Uri.EscapeDataString(_ssoSlug.Trim().ToLowerInvariant());
        Navigation.NavigateTo($"/api/sso/{slug}/start", forceLoad: true);
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var success = await AuthService.LoginAsync(loginModel);

            if (success)
            {
                var user = await AuthService.GetCurrentUserAsync();

                if (user != null)
                {
                    var defaultRoute = user.Role switch
                    {
                        "SuperAdmin" => "/superadmin/dashboard",
                        "OrganizationAdmin" => user.NeedsOnboarding ? "/onboarding" : "/admin/dashboard",
                        "Manager" => "/manager/dashboard",
                        "User" => "/user/dashboard",
                        _ => "/"
                    };

                    var route = IsSafeLocalReturnUrl(ReturnUrl) ? ReturnUrl! : defaultRoute;
                    Navigation.NavigateTo(route, true);
                }
            }
            else
            {
                errorMessage = "Invalid username or password. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred. Please try again later.";
            Console.WriteLine($"Login error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private static bool IsSafeLocalReturnUrl(string? returnUrl) =>
        !string.IsNullOrWhiteSpace(returnUrl) &&
        returnUrl.StartsWith('/') &&
        !returnUrl.StartsWith("//") &&
        !returnUrl.StartsWith("/\\");
}
