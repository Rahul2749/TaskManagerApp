@* TaskManager.Client/Pages/Home.razor *@
@page "/"
@layout TaskManager.Client.Components.Layout.LoginLayout

@using TaskManager.Client.Components
@inject NavigationManager Navigation

<div class="landing-page">
    <!-- Ethereal Background Glows -->
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>
    <div class="glow-orb orb-3"></div>

    <!-- Header Section -->
    <header class="landing-header fade-in">
        <div class="header-logo">
            <div class="logo-icon-wrapper">
                <i class="ph-fill ph-clipboard-text"></i>
            </div>
            <span class="logo-text">TaskManager<span class="text-cyan">.</span></span>
        </div>
        <div class="header-actions">
            <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/pricing">Pricing</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">Sign In</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="StartFreeTrial">Get Started</MudButton>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content slide-up stagger-1">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                <span>The Future of Productivity</span>
            </div>

            <h1 class="hero-title">
                Manage your work with<br />
                <span class="gradient-text">Absolute Precision</span>
            </h1>

            <p class="hero-description">
                Experience the most elegant, powerful, and blazing-fast task management platform designed for elite teams.
            </p>

            <div class="hero-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="GetStarted">
                    Start Your Journey
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.PlayCircle" OnClick="ViewDemo">
                    Watch Demo
                </MudButton>
            </div>
        </div>

        <div class="hero-visual slide-up stagger-2">
            <!-- 3D Glass Mockup -->
            <div class="mockup-container glass-panel">
                <div class="mockup-header">
                    <div class="mockup-dots"><span></span><span></span><span></span></div>
                    <div class="mockup-search"></div>
                </div>
                <div class="mockup-body">
                    <!-- Fake dashboard UI -->
                    <div class="mockup-sidebar"></div>
                    <div class="mockup-content">
                        <div class="mockup-card c1"></div>
                        <div class="mockup-card c2"></div>
                        <div class="mockup-card c3"></div>
                    </div>
                </div>
                
                <!-- Floating Elements -->
                <div class="floating-glass f1">
                    <i class="ph-fill ph-check-circle text-cyan"></i>
                    <span>Project Alpha Shipped</span>
                </div>
                <div class="floating-glass f2">
                    <div class="avatar-stack">
                        <div class="avatar avatar-sm">A</div>
                        <div class="avatar avatar-sm">B</div>
                    </div>
                    <span>Team sync at 2PM</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
        <div class="section-header slide-up stagger-3">
            <h2 class="section-title">Engineered for <span class="text-cyan">Excellence</span></h2>
            <p class="section-description">A complete suite of tools hidden behind a masterfully crafted, distraction-free interface.</p>
        </div>

        <div class="features-bento slide-up stagger-4">
            <div class="bento-card glass-panel bento-large">
                <div class="bento-icon"><i class="ph-duotone ph-kanban"></i></div>
                <h3>Intuitive Boards</h3>
                <p>Drag, drop, and conquer. Our kanban boards are silky smooth and incredibly responsive.</p>
            </div>
            <div class="bento-card glass-panel">
                <div class="bento-icon"><i class="ph-duotone ph-lightning"></i></div>
                <h3>Real-time Sync</h3>
                <p>Changes reflect instantly across all your devices.</p>
            </div>
            <div class="bento-card glass-panel">
                <div class="bento-icon"><i class="ph-duotone ph-chart-line-up"></i></div>
                <h3>Deep Analytics</h3>
                <p>Understand your team's velocity with beautiful charts.</p>
            </div>
            <div class="bento-card glass-panel bento-wide">
                <div class="bento-icon"><i class="ph-duotone ph-lock-key"></i></div>
                <h3>Enterprise Security</h3>
                <p>Your data is encrypted at rest and in transit. Bank-level security for your peace of mind.</p>
            </div>
        </div>
    </section>
</div>

<style>
    /* LANDING PAGE STYLES */
    .landing-page {
        position: relative;
        overflow: hidden;
        min-height: 100vh;
        background: var(--bg-main);
    }

    /* BACKGROUND ORBS */
    .glow-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.5;
        pointer-events: none;
        z-index: 0;
        animation: pulseOrb 10s ease-in-out infinite alternate;
    }

    .orb-1 {
        top: -10%; left: -10%; width: 40vw; height: 40vw;
        background: rgba(99, 102, 241, 0.4);
    }
    .orb-2 {
        bottom: -20%; right: -10%; width: 50vw; height: 50vw;
        background: rgba(6, 182, 212, 0.3);
        animation-delay: -5s;
    }
    .orb-3 {
        top: 40%; left: 50%; width: 30vw; height: 30vw;
        background: rgba(139, 92, 246, 0.2);
        transform: translate(-50%, -50%);
    }

    @@keyframes pulseOrb {
        0% { transform: scale(1) translate(0, 0); opacity: 0.4; }
        100% { transform: scale(1.2) translate(5%, 5%); opacity: 0.7; }
    }

    /* HEADER */
    .landing-header {
        position: relative;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 4rem;
        max-width: 1440px;
        margin: 0 auto;
    }

    .header-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .logo-icon-wrapper {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, var(--accent-purple), var(--accent-cyan));
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: var(--glow-primary);
    }

    .btn-text {
        color: var(--text-secondary);
        font-weight: 600;
        text-decoration: none;
        padding: 8px 16px;
        transition: color 0.3s;
    }
    .btn-text:hover { color: white; }

    /* HERO */
    .hero-section {
        position: relative;
        z-index: 10;
        max-width: 1440px;
        margin: 0 auto;
        padding: 0rem 4rem 2rem;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 2rem;
        align-items: center;
        height: calc(100vh - 100px);
        min-height: 600px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 2rem;
        backdrop-filter: blur(10px);
    }

    .badge-dot {
        width: 8px; height: 8px;
        background: var(--accent-cyan);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--accent-cyan);
    }

    .hero-title {
        font-size: 3.8rem;
        line-height: 1.1;
        margin-bottom: 1rem;
    }

    .hero-description {
        font-size: 1.15rem;
        color: var(--text-secondary);
        max-width: 500px;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .hero-actions {
        display: flex;
        gap: 1.5rem;
    }

    .btn-lg {
        padding: 16px 32px;
        font-size: 1.1rem;
    }

    /* MOCKUP VISUAL */
    .hero-visual {
        position: relative;
        perspective: 1000px;
    }

    .mockup-container {
        width: 95%;
        height: 420px;
        margin: 0 auto;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transform: rotateY(-10deg) rotateX(5deg);
        box-shadow: -20px 20px 50px rgba(0, 0, 0, 0.5);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: floatMockup 6s ease-in-out infinite alternate;
    }

    @@keyframes floatMockup {
        0% { transform: rotateY(-10deg) rotateX(5deg) translateY(0); }
        100% { transform: rotateY(-8deg) rotateX(3deg) translateY(-20px); }
    }

    .mockup-header {
        height: 40px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex; align-items: center; padding: 0 16px; gap: 20px;
    }

    .mockup-dots span {
        display: inline-block; width: 10px; height: 10px; border-radius: 50%;
        background: #475569; margin-right: 6px;
    }

    .mockup-search {
        height: 20px; width: 200px; background: rgba(255, 255, 255, 0.05); border-radius: 10px;
    }

    .mockup-body {
        display: flex; flex: 1; padding: 16px; gap: 16px;
    }

    .mockup-sidebar {
        width: 60px; border-radius: 8px; background: rgba(255, 255, 255, 0.02);
    }

    .mockup-content {
        flex: 1; display: grid; gap: 16px;
    }

    .mockup-card { background: rgba(255, 255, 255, 0.05); border-radius: 8px; }
    .c1 { height: 100px; }
    .c2 { height: 60px; }
    .c3 { height: 120px; opacity: 0.5; }

    /* FLOATING ELEMENTS */
    .floating-glass {
        position: absolute;
        background: rgba(20, 20, 30, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 16px 24px;
        border-radius: 16px;
        display: flex; align-items: center; gap: 12px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        color: white; font-weight: 600; font-size: 0.9rem;
        animation: floatCard 4s ease-in-out infinite alternate;
    }

    .f1 { top: 10%; right: -5%; animation-delay: 1s; }
    .f2 { bottom: 15%; left: -5%; animation-delay: 2s; }

    @@keyframes floatCard {
        0% { transform: translateY(0); }
        100% { transform: translateY(-15px); }
    }

    .avatar-stack { display: flex; }
    .avatar-stack .avatar { margin-left: -10px; border: 2px solid #16161E; }
    .avatar-stack .avatar:first-child { margin-left: 0; }

    /* BENTO FEATURES */
    .features-section {
        position: relative;
        z-index: 10;
        max-width: 1440px;
        margin: 0 auto;
        padding: 6rem 4rem;
    }

    .section-header { text-align: center; margin-bottom: 4rem; }
    .section-title { font-size: 3.5rem; margin-bottom: 1rem; }
    .section-description { font-size: 1.25rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto; }

    .features-bento {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: minmax(200px, auto);
        gap: 24px;
    }

    .bento-card {
        padding: 2.5rem;
        display: flex; flex-direction: column; justify-content: center;
        transition: transform 0.4s;
    }
    .bento-card:hover { transform: translateY(-5px); border-color: rgba(99, 102, 241, 0.4); }

    .bento-large { grid-column: span 2; grid-row: span 2; }
    .bento-wide { grid-column: span 2; }

    .bento-icon {
        font-size: 2.5rem;
        color: var(--accent-cyan);
        margin-bottom: 1.5rem;
    }

    .bento-card h3 { margin-bottom: 0.5rem; font-size: 1.5rem; }
    .bento-card p { color: var(--text-secondary); line-height: 1.6; }

    @@media (max-width: 1024px) {
        .hero-section { grid-template-columns: 1fr; text-align: center; padding: 4rem 2rem; }
        .hero-actions { justify-content: center; }
        .hero-visual { display: none; }
        .features-bento { grid-template-columns: 1fr; }
        .bento-large, .bento-wide { grid-column: span 1; grid-row: span 1; }
        .hero-title { font-size: 3.5rem; }
    }
</style>

@code {
    private void GetStarted()
    {
        Navigation.NavigateTo("/login");
    }

    private void StartFreeTrial()
    {
        Navigation.NavigateTo("/login");
    }

    private void ViewDemo()
    {
        Console.WriteLine("View Demo clicked");
    }
}
