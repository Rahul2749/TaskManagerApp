<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4 flex-wrap gap-3">
    <div>
        @if (!string.IsNullOrEmpty(Title))
        {
            <MudText Typo="Typo.h5" Class="mb-1">@Title</MudText>
        }
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Subtitle</MudText>
        }
    </div>
    @if (Actions is not null)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="gap-2">
            @Actions
        </MudStack>
    }
</MudStack>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
