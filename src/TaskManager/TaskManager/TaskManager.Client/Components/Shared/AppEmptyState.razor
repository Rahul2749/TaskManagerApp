<MudPaper Class="glass-card pa-8 text-center" Elevation="0">
    <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
    <MudText Typo="Typo.h6" Class="mb-1">@Title</MudText>
    @if (!string.IsNullOrEmpty(Description))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@Description</MudText>
    }
    @if (Actions is not null)
    {
        @Actions
    }
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "Nothing here yet";
    [Parameter] public string? Description { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
