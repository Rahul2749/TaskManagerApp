@* TaskManager.Client/Components/Layout/Header.razor *@
@implements IDisposable
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject NavigationManager Navigation
@inject IAuthServiceClient AuthService
@inject SidebarStateService SidebarState

<header class="content-header">
    <div class="header-wrapper">
        <!-- Mobile Menu Button -->
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Class="mobile-menu-mud"
                       OnClick="HandleMenuClick"
                       title="Menu" />

        <!-- Page Title -->
        <h2 class="page-title">@Title</h2>

        <!-- Header Actions -->
        <div class="header-actions">
            @if (isAuthenticated)
            {
                <MudBadge Content="@(NotificationCount > 0 ? NotificationCount.ToString() : null)" Color="Color.Error" Overlap="true" Visible="@(NotificationCount > 0)">
                    <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" OnClick="HandleNotifications" />
                </MudBadge>

                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="user-mud-menu">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="user-menu-trigger" EndIcon="@Icons.Material.Filled.ArrowDropDown">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">@userInitial</MudAvatar>
                            @if (!string.IsNullOrEmpty(userName))
                            {
                                <span class="user-name-text">@userName</span>
                            }
                        </MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Disabled="true" Class="user-menu-header">
                            <div>
                                <MudText Typo="Typo.subtitle2">@userName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@userEmail</MudText>
                            </div>
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Person" OnClick="HandleProfile">Profile</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="HandleSettings">Settings</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error" OnClick="HandleLogout">Logout</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleLogin">Login</MudButton>
            }
        </div>
    </div>
</header>

<style>
    /* CONTENT HEADER */
    .content-header {
        background: rgba(10, 10, 15, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-light);
        padding: var(--space-md) var(--space-xl);
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .content-header.menu-open {
        z-index: 1100;
    }

    /* For home/landing page - minimal padding */
    body:has(.landing-page) .content-header {
        padding: var(--space-md) var(--space-xl);
    }

    .header-wrapper {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        width: 100%;
    }


    .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
        flex: 1;
        line-height: 1.2;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        flex-shrink: 0;
    }

    .user-menu-trigger {
        text-transform: none !important;
        border-color: rgba(255,255,255,0.12) !important;
    }

    .user-name-text {
        font-size: 0.875rem;
        font-weight: 600;
        max-width: 120px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    @@media (max-width: 768px) {
        .user-name-text { display: none; }
    }

    @@media (max-width: 1024px) {
        .content-header

    {
        padding: var(--space-sm) var(--space-md);
    }

    }

    @@media (max-width: 768px) {
        .content-header

    {
        padding: var(--space-sm) var(--space-md);
    }

    }

    @@media (max-width: 480px) {
        .content-header

    {
        padding: var(--space-sm);
    }

    }

    .mobile-menu-mud {
        display: none;
        flex-shrink: 0;
    }

    @@media (max-width: 1024px) {
        .mobile-menu-mud {
            display: inline-flex;
        }
    }
</style>

@code {
    [Parameter] public string Title { get; set; } = "Dashboard";
    [Parameter] public int NotificationCount { get; set; } = 0;
    [Parameter] public bool ShowAddButton { get; set; } = false;
    [Parameter] public string AddButtonText { get; set; } = "Add Task";

    private bool isAuthenticated = false;
    private string userName = string.Empty;
    private string userEmail = string.Empty;
    private string userInitial = "U";

    protected override async Task OnInitializedAsync()
    {
        await LoadUserData();
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = RefreshUserDataAsync();
    }

    private async Task RefreshUserDataAsync()
    {
        await LoadUserData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadUserData()
    {
        var user = await AuthService.GetCurrentUserAsync();
        isAuthenticated = user != null;

        if (user != null)
        {
            userName = user.FullName ?? user.Username;
            userEmail = user.Email;
            userInitial = string.IsNullOrEmpty(user.FirstName)
                ? user.Username.Substring(0, 1).ToUpper()
                : user.FirstName.Substring(0, 1).ToUpper();
        }
        else
        {
            userName = string.Empty;
            userEmail = string.Empty;
            userInitial = "U";
        }
    }

    private void HandleMenuClick()
    {
        SidebarState.ToggleMobileSidebar();
    }

    private void HandleNotifications() => Navigation.NavigateTo("/notifications");

    private void HandleProfile() => Navigation.NavigateTo("/profile");

    private void HandleSettings() => Navigation.NavigateTo("/settings");

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        await LoadUserData();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void HandleLogin()
    {
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}