@using TaskManager.Client.Components.Layout
@using TaskManager.Client.Services
@inherits LayoutComponentBase
@implements IDisposable
@inject INotificationRealtimeService Notifications
@inject IAuthServiceClient AuthService

<MudAppProviders>
<div class="app-layout">
    <!-- Ethereal Background for the whole app -->
    <div class="app-bg-glow"></div>

    <!-- SIDEBAR -->
    <NavMenu />

    <!-- MAIN CONTENT -->
    <main class="app-main">
        <!-- Header Component -->
        <Header NotificationCount="_unreadCount"
                ShowAddButton="true"
                AddButtonText="Add Task" />

        <!-- Page Content -->
        <div class="content-body">
            @Body
        </div>
    </main>
</div>
</MudAppProviders>

<style>
    .app-layout {
        display: flex;
        min-height: 100vh;
        background: var(--bg-main);
        position: relative;
        overflow: hidden;
    }

    .app-bg-glow {
        position: fixed;
        top: -20%; right: -10%;
        width: 60vw; height: 60vw;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
    }

    .app-main {
        flex: 1;
        margin-left: var(--sidebar-width);
        transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        min-width: 0;
        width: 100%;
        position: relative;
        z-index: 1;
    }

    .content-body {
        flex: 1;
        padding: var(--space-lg) var(--space-xl) var(--space-xl);
        overflow-y: auto;
        overflow-x: hidden;
        height: calc(100vh - 80px); /* header offset */
    }
    
    .content-body::-webkit-scrollbar {
        width: 6px;
    }
    .content-body::-webkit-scrollbar-track {
        background: transparent;
    }
    .content-body::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    .content-body::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    /* Reduce top padding for landing page */
    .landing-page {
        margin-top: calc(var(--space-lg) * -1);
    }

    @@media (max-width: 1024px) {
        .app-main {
            margin-left: 0 !important;
        }
        .content-body {
            padding: var(--space-md) var(--space-lg) var(--space-lg);
        }
    }
</style>

<script>
    (function() {
        function adjustMainMargin() {
            const sidebar = document.querySelector('.app-sidebar');
            const mainContent = document.querySelector('.app-main');

            if (mainContent) {
                if (!sidebar || window.getComputedStyle(sidebar).display === 'none') {
                    mainContent.style.marginLeft = '0px';
                } else if (window.innerWidth > 1024) {
                    const collapsed = sidebar.classList.contains('collapsed');
                    mainContent.style.marginLeft = collapsed ? 'var(--sidebar-collapsed-width)' : 'var(--sidebar-width)';
                }
            }
        }

        function initAnimations() {
            if (typeof gsap === 'undefined') return;
            
            const sidebar = document.querySelector('.app-sidebar');
            const content = document.querySelector('.content-body');
            const header = document.querySelector('.content-header');

            if (sidebar && !sidebar.classList.contains('animated')) {
                sidebar.classList.add('animated');
                gsap.fromTo(sidebar, 
                    { x: -50, opacity: 0 }, 
                    { x: 0, opacity: 1, duration: 0.6, ease: 'power3.out' }
                );
            }

            if (header && !header.classList.contains('animated')) {
                header.classList.add('animated');
                gsap.fromTo(header, 
                    { y: -20, opacity: 0 }, 
                    { y: 0, opacity: 1, duration: 0.5, delay: 0.2, ease: 'power2.out' }
                );
            }

            if (content && !content.classList.contains('animated')) {
                content.classList.add('animated');
                gsap.fromTo(content, 
                    { y: 30, opacity: 0 }, 
                    { y: 0, opacity: 1, duration: 0.6, delay: 0.3, ease: 'power3.out' }
                );
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => {
                adjustMainMargin();
                setTimeout(initAnimations, 100);
            });
        } else {
            adjustMainMargin();
            setTimeout(initAnimations, 100);
        }

        const observer = new MutationObserver((mutations) => {
            adjustMainMargin();
            mutations.forEach((mutation) => {
                if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
                    const content = document.querySelector('.content-body');
                    if (content) {
                        content.classList.remove('animated');
                        initAnimations();
                    }
                }
            });
        });
        observer.observe(document.body, { childList: true, subtree: true });

        let checks = 0;
        const interval = setInterval(() => {
            adjustMainMargin();
            initAnimations();
            checks++;
            if (checks > 10) clearInterval(interval);
        }, 200);
    })();
</script>

@code {
    private int _unreadCount;

    protected override async Task OnInitializedAsync()
    {
        Notifications.Changed += OnNotificationsChanged;
        var user = await AuthService.GetCurrentUserAsync();
        if (user is not null)
            await Notifications.EnsureConnectedAsync();
        _unreadCount = Notifications.UnreadCount;
    }

    private void OnNotificationsChanged()
    {
        _unreadCount = Notifications.UnreadCount;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Notifications.Changed -= OnNotificationsChanged;
    }
}
