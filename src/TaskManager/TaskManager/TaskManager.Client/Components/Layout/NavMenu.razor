@* TaskManager.Client/Components/Layout/NavMenu.razor *@
@implements IDisposable
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject IAuthServiceClient AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject SidebarStateService SidebarState

@if (isAuthenticated)
{
    <!-- Mobile Overlay -->
    <div class="mobile-overlay @(isMobileSidebarOpen ? "active" : "")" @onclick="CloseMobileSidebar"></div>

    <aside class="app-sidebar @(isSidebarCollapsed ? "collapsed" : "") @(isMobileSidebarOpen ? "mobile-open" : "")" id="appSidebar">
        <!-- Brand Logo -->
        <div class="sidebar-brand">
            <div class="brand-content">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Class="brand-mud-icon" />
                @if (!isSidebarCollapsed)
                {
                    <MudText Typo="Typo.h6" Class="brand-text">TaskManager</MudText>
                }
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Color="Color.Inherit"
                           Class="mobile-close-mud"
                           OnClick="CloseMobileSidebar"
                           title="Close" />
        </div>

        <!-- Navigation Menu -->
        <nav class="sidebar-nav">
            @if (!string.IsNullOrEmpty(currentUserRole))
            {
                <div class="nav-section">
                    @if (!isSidebarCollapsed)
                    {
                        <div class="section-label">MAIN MENU</div>
                    }

                    <MudNavMenu Class="sidebar-mud-nav" Bordered="false" Color="Color.Inherit">
                        @if (currentUserRole == "SuperAdmin")
                        {
                            <MudNavLink Href="superadmin/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard" OnClick="CloseMobileSidebar">
                                @NavText("Dashboard")
                            </MudNavLink>
                            <MudNavLink Href="superadmin/organizations" Icon="@Icons.Material.Filled.Business" OnClick="CloseMobileSidebar">
                                @NavText("Organizations")
                            </MudNavLink>
                            <MudNavLink Href="superadmin/users" Icon="@Icons.Material.Filled.People" OnClick="CloseMobileSidebar">
                                @NavText("All Users")
                            </MudNavLink>
                            <MudNavLink Href="superadmin/reports" Icon="@Icons.Material.Filled.BarChart" OnClick="CloseMobileSidebar">
                                @NavText("Reports")
                            </MudNavLink>
                        }
                        else if (currentUserRole == "OrganizationAdmin")
                        {
                            <MudNavLink Href="admin/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard" OnClick="CloseMobileSidebar">
                                @NavText("Dashboard")
                            </MudNavLink>
                            <MudNavLink Href="admin/managers" Icon="@Icons.Material.Filled.Work" OnClick="CloseMobileSidebar">
                                @NavText("Managers")
                            </MudNavLink>
                            <MudNavLink Href="invites" Icon="@Icons.Material.Filled.MailOutline" OnClick="CloseMobileSidebar">
                                @NavText("Invites")
                            </MudNavLink>
                            <MudNavLink Href="admin/reports" Icon="@Icons.Material.Filled.BarChart" OnClick="CloseMobileSidebar">
                                @NavText("Reports")
                            </MudNavLink>
                            <MudNavLink Href="billing" Icon="@Icons.Material.Filled.CreditCard" OnClick="CloseMobileSidebar">
                                @NavText("Billing")
                            </MudNavLink>
                        }
                        else if (currentUserRole == "Manager")
                        {
                            <MudNavLink Href="manager/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard" OnClick="CloseMobileSidebar">
                                @NavText("Dashboard")
                            </MudNavLink>
                            <MudNavLink Href="manager/projects" Icon="@Icons.Material.Filled.Folder" OnClick="CloseMobileSidebar">
                                @NavText("Projects")
                            </MudNavLink>
                            <MudNavLink Href="manager/tasks" Icon="@Icons.Material.Filled.TaskAlt" OnClick="CloseMobileSidebar">
                                @NavText("Tasks")
                            </MudNavLink>
                            <MudNavLink Href="manager/users" Icon="@Icons.Material.Filled.People" OnClick="CloseMobileSidebar">
                                @NavText("Team Members")
                            </MudNavLink>
                            <MudNavLink Href="invites" Icon="@Icons.Material.Filled.MailOutline" OnClick="CloseMobileSidebar">
                                @NavText("Invites")
                            </MudNavLink>
                            <MudNavLink Href="manager/project-users" Icon="@Icons.Material.Filled.Link" OnClick="CloseMobileSidebar">
                                @NavText("Project Mapping")
                            </MudNavLink>
                        }
                        else if (currentUserRole == "User")
                        {
                            <MudNavLink Href="user/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard" OnClick="CloseMobileSidebar">
                                @NavText("Dashboard")
                            </MudNavLink>
                            <MudNavLink Href="user/tasks" Icon="@Icons.Material.Filled.TaskAlt" OnClick="CloseMobileSidebar">
                                @NavText("My Tasks")
                            </MudNavLink>
                        }
                    </MudNavMenu>
                </div>
            }
        </nav>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer">
            @if (!isSidebarCollapsed)
            {
                <div class="section-label">ACCOUNT</div>
            }

            @if (!string.IsNullOrEmpty(currentUserName))
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="user-profile mb-3">
                    <MudAvatar Color="Color.Primary" Size="Size.Small">@currentUserInitial</MudAvatar>
                    @if (!isSidebarCollapsed)
                    {
                        <div class="user-info">
                            <MudText Typo="Typo.body2" Class="user-name">@currentUserName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@currentUserRole</MudText>
                        </div>
                    }
                </MudStack>
            }

            <MudButton Variant="Variant.Text"
                       Color="Color.Error"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Logout"
                       OnClick="HandleLogout"
                       Class="logout-mud-btn">
                @if (!isSidebarCollapsed)
                {
                    <span>Logout</span>
                }
            </MudButton>
        </div>

        <!-- Toggle Button (Desktop only) -->
        <button type="button"
                class="sidebar-toggle desktop-only"
                @onclick="ToggleSidebar"
                aria-label="@(isSidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")"
                title="@(isSidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")">
            <MudIcon Icon="@(isSidebarCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ChevronLeft)"
                     Class="sidebar-toggle-icon" />
        </button>
    </aside>
}

<style>
    /* MOBILE OVERLAY */
    .mobile-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 998;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .mobile-overlay.active {
            display: block;
            opacity: 1;
            pointer-events: all;
        }

    /* SIDEBAR */
    .app-sidebar {
        width: var(--sidebar-width);
        background: var(--bg-sidebar);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-right: 1px solid var(--border-color);
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease, width 0.3s ease;
        z-index: 999;
    }

        .app-sidebar.collapsed {
            width: var(--sidebar-collapsed-width);
        }

    /* BRAND */
    .sidebar-brand {
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 var(--space-lg);
        border-bottom: 1px solid var(--border-light);
        flex-shrink: 0;
    }

    .brand-content {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .brand-mud-icon {
        font-size: 1.75rem !important;
    }

    .mobile-close-mud {
        display: none;
    }

    .sidebar-mud-nav {
        background: transparent !important;
        padding: 0 !important;
    }

    .sidebar-mud-nav .mud-nav-link {
        border-radius: var(--radius-sm);
        margin-bottom: 4px;
        color: var(--text-sidebar) !important;
    }

    .sidebar-mud-nav .mud-nav-link.active {
        background: var(--bg-sidebar-active) !important;
        color: var(--text-sidebar-active) !important;
        font-weight: 600;
    }

    .app-sidebar.collapsed .sidebar-mud-nav .mud-nav-link-text {
        display: none;
    }

    .app-sidebar.collapsed .sidebar-mud-nav .mud-nav-link {
        justify-content: center;
        min-width: 48px;
        padding-left: 12px;
        padding-right: 12px;
    }

    .logout-mud-btn {
        justify-content: flex-start !important;
        text-transform: none !important;
    }

    .app-sidebar.collapsed .logout-mud-btn {
        justify-content: center !important;
        min-width: 48px;
    }

    /* BRAND */
    .sidebar-nav {
        flex: 1;
        padding: var(--space-lg) var(--space-md);
        overflow-y: auto;
        overflow-x: hidden;
    }

    .nav-section {
        margin-bottom: var(--space-lg);
    }

    .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--text-sidebar);
        letter-spacing: 1px;
        margin-bottom: var(--space-md);
        padding: 0 var(--space-sm);
    }

    .nav-menu {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 16px;
        border-radius: var(--radius-sm);
        color: var(--text-sidebar);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.2s ease;
        position: relative;
    }

        .nav-link:hover {
            background: var(--bg-sidebar-hover);
            color: var(--text-sidebar-active);
        }

        .nav-link.active {
            background: var(--bg-sidebar-active);
            color: var(--text-sidebar-active);
            font-weight: 600;
        }

            .nav-link.active::before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 4px;
                height: 70%;
                background: var(--accent-purple);
                border-radius: 0 4px 4px 0;
            }

    .nav-icon {
        font-size: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 24px;
    }

    .nav-text {
        white-space: nowrap;
    }

    .app-sidebar.collapsed .nav-link {
        justify-content: center;
    }

        .app-sidebar.collapsed .nav-link:hover::after {
            content: attr(title);
            position: absolute;
            left: calc(100% + 12px);
            background: var(--text-primary);
            color: white;
            padding: 8px 14px;
            border-radius: 8px;
            font-size: 0.875rem;
            white-space: nowrap;
            z-index: 1001;
            box-shadow: var(--shadow-md);
        }

    /* SIDEBAR FOOTER */
    .sidebar-footer {
        padding: var(--space-lg) var(--space-md);
        border-top: 1px solid var(--border-light);
        flex-shrink: 0;
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        background: var(--bg-sidebar-hover);
        border-radius: var(--radius-sm);
        margin-bottom: var(--space-md);
    }

    .app-sidebar.collapsed .user-profile {
        justify-content: center;
        padding: 12px 8px;
    }

    .user-info {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .sidebar-link {
        width: 100%;
        display: flex;
        align-items: center;
        gap: var(--space-md);
        padding: 12px var(--space-md);
        background: none;
        border: none;
        border-radius: var(--radius-sm);
        color: var(--text-sidebar);
        cursor: pointer;
        transition: all 0.2s;
        font-size: 0.95rem;
        font-weight: 500;
        text-align: left;
    }

        .sidebar-link:hover {
            background: var(--bg-sidebar-hover);
            color: var(--text-sidebar-active);
        }

    .logout-btn:hover {
        background: var(--accent-energy);
        color: var(--color-danger);
    }

    .link-icon {
        font-size: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 24px;
    }

    .app-sidebar.collapsed .sidebar-link {
        justify-content: center;
    }

    /* SIDEBAR TOGGLE */
    .sidebar-toggle {
        position: absolute;
        right: -12px;
        top: 90px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--accent-purple);
        color: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-md);
        transition: all 0.2s;
        z-index: 10;
        padding: 0;
    }

        .sidebar-toggle .sidebar-toggle-icon {
            color: white !important;
            font-size: 18px !important;
            line-height: 1;
            pointer-events: none;
        }

        .sidebar-toggle:hover {
            transform: scale(1.1);
            background: var(--accent-purple-hover);
        }

        .sidebar-toggle:focus-visible {
            outline: 2px solid white;
            outline-offset: 2px;
        }

    /* RESPONSIVE */
    @@media (max-width: 1024px) {
        .app-sidebar

    {
        transform: translateX(-100%);
    }

    .app-sidebar.mobile-open {
        transform: translateX(0);
    }

    .mobile-close-mud {
        display: flex;
    }

    .desktop-only {
        display: none !important;
    }

    .app-sidebar.collapsed {
        width: var(--sidebar-width);
    }

        .app-sidebar.collapsed .nav-link,
        .app-sidebar.collapsed .sidebar-link {
            justify-content: flex-start;
        }

    }

    @@media (max-width: 768px) {
        .sidebar-brand

    {
        height: 70px;
        padding: 0 var(--space-md);
    }

    .brand-icon {
        font-size: 1.5rem;
    }

    .brand-text {
        font-size: 1.125rem;
    }

    }

    @@media (max-width: 480px) {
        .app-sidebar

    {
        width: 280px;
    }

    .sidebar-brand {
        height: 60px;
    }

    }
</style>

@code {
    private bool isSidebarCollapsed = false;
    private bool isMobileSidebarOpen = false;
    private bool isAuthenticated = false;
    private string currentUserRole = string.Empty;
    private string currentUserName = string.Empty;
    private string currentUserInitial = "U";

    protected override async Task OnInitializedAsync()
    {
        await LoadUserData();
        Navigation.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await LoadUserData();
        StateHasChanged();
    }

    private async Task LoadUserData()
    {
        var user = await AuthService.GetCurrentUserAsync();
        isAuthenticated = user != null;

        if (user != null)
        {
            currentUserRole = user.Role;
            currentUserName = user.FullName ?? user.Username;
            currentUserInitial = string.IsNullOrEmpty(user.FirstName)
                ? user.Username.Substring(0, 1).ToUpper()
                : user.FirstName.Substring(0, 1).ToUpper();
        }
        else
        {
            currentUserRole = string.Empty;
            currentUserName = string.Empty;
            currentUserInitial = "U";
        }
    }

    private async Task ToggleSidebar()
    {
        isSidebarCollapsed = !isSidebarCollapsed;
        await UpdateMainMargin();
        StateHasChanged();
    }

    private async void CloseMobileSidebar()
    {
        SidebarState.CloseMobileSidebar();

        try
        {
            await JSRuntime.InvokeVoidAsync("eval", @"
                const sidebar = document.getElementById('appSidebar');
                const overlay = document.querySelector('.mobile-overlay');
                if (sidebar) sidebar.classList.remove('mobile-open');
                if (overlay) overlay.classList.remove('active');
            ");
        }
        catch
        {
            // Ignore JS errors
        }
        StateHasChanged();
    }

    public static class HeaderComponent
    {
        public static bool isMobileSidebarOpen = false;
    }

    private async Task UpdateMainMargin()
    {
        try
        {
            var marginLeft = isSidebarCollapsed ? "80px" : "260px";
            await JSRuntime.InvokeVoidAsync("eval", $@"
                (function() {{
                    const mainContent = document.querySelector('.app-main');
                    if (mainContent) {{
                        if (window.innerWidth > 1024) {{
                            mainContent.style.marginLeft = '{marginLeft}';
                        }} else {{
                            mainContent.style.marginLeft = '0';
                        }}
                    }}
                }})();
            ");
        }
        catch
        {
            // Ignore JS errors
        }
    }

    private async Task HandleLogout()
    {
        CloseMobileSidebar();
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private RenderFragment NavText(string text) => builder =>
    {
        if (!isSidebarCollapsed)
        {
            builder.AddContent(0, text);
        }
    };

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
