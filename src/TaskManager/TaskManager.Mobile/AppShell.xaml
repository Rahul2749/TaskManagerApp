<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:TaskManager.Mobile.Views"
       x:Class="TaskManager.Mobile.AppShell"
       Shell.FlyoutBehavior="Flyout"
       Shell.FlyoutBackgroundColor="{StaticResource SoftestFrost}"
       Shell.NavBarHasShadow="False"
       Shell.BackgroundColor="{StaticResource SoftestFrost}"
       Shell.ForegroundColor="{StaticResource PrimaryAccent}"
       Shell.TitleColor="{StaticResource TextPrimary}"
       Shell.UnselectedColor="{StaticResource TextMuted}"
       Title="TaskManager">

    <Shell.FlyoutHeaderTemplate>
        <DataTemplate>
            <Grid BackgroundColor="{StaticResource DeepCerulean}" HeightRequest="168" Padding="20,24">
                <VerticalStackLayout VerticalOptions="End" Spacing="6">
                    <Border WidthRequest="52" HeightRequest="52" StrokeThickness="0"
                            StrokeShape="RoundRectangle 26"
                            BackgroundColor="{StaticResource SoftCerulean}"
                            HorizontalOptions="Start">
                        <Label Text="TM" TextColor="White" FontSize="18"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="TaskManager" TextColor="White" FontSize="20" FontAttributes="Bold" />
                    <Label Text="Your workspace" TextColor="{StaticResource CeruleanTint}" FontSize="13" />
                </VerticalStackLayout>
            </Grid>
        </DataTemplate>
    </Shell.FlyoutHeaderTemplate>

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="16,12" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Border WidthRequest="36" HeightRequest="36" StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{StaticResource IceBlue}"
                        VerticalOptions="Center">
                    <Image Source="{Binding Icon}" WidthRequest="18" HeightRequest="18"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Grid.Column="1" Text="{Binding Title}"
                       TextColor="{StaticResource TextPrimary}"
                       VerticalOptions="Center" FontSize="15" FontAttributes="Bold" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <FlyoutItem Title="Dashboard" Icon="nav_dashboard.png">
        <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" Route="dashboard" />
    </FlyoutItem>

    <FlyoutItem x:Name="ReportsFlyoutItem" Title="Reports" Icon="nav_dashboard.png">
        <ShellContent ContentTemplate="{DataTemplate views:ReportsPage}" Route="reports" />
    </FlyoutItem>

    <FlyoutItem Title="Tasks" Icon="nav_tasks.png">
        <ShellContent ContentTemplate="{DataTemplate views:TasksPage}" Route="tasks" />
    </FlyoutItem>

    <FlyoutItem Title="Board" Icon="nav_tasks.png">
        <ShellContent ContentTemplate="{DataTemplate views:BoardPage}" Route="board" />
    </FlyoutItem>

    <FlyoutItem Title="Calendar" Icon="nav_tasks.png">
        <ShellContent ContentTemplate="{DataTemplate views:CalendarPage}" Route="calendar" />
    </FlyoutItem>

    <FlyoutItem Title="Timeline" Icon="nav_dashboard.png">
        <ShellContent ContentTemplate="{DataTemplate views:TimelinePage}" Route="timeline" />
    </FlyoutItem>

    <FlyoutItem Title="Timesheets" Icon="nav_tasks.png">
        <ShellContent ContentTemplate="{DataTemplate views:TimesheetsPage}" Route="timesheets" />
    </FlyoutItem>

    <FlyoutItem Title="Automations" Icon="nav_projects.png">
        <ShellContent ContentTemplate="{DataTemplate views:AutomationsPage}" Route="automations" />
    </FlyoutItem>

    <FlyoutItem x:Name="NotificationsFlyoutItem" Title="Notifications" Icon="nav_tasks.png">
        <ShellContent ContentTemplate="{DataTemplate views:NotificationsPage}" Route="notifications" />
    </FlyoutItem>

    <FlyoutItem Title="Activity" Icon="nav_dashboard.png">
        <ShellContent ContentTemplate="{DataTemplate views:ActivityPage}" Route="activity" />
    </FlyoutItem>

    <FlyoutItem Title="Projects" x:Name="ProjectsFlyoutItem" Icon="nav_projects.png">
        <ShellContent ContentTemplate="{DataTemplate views:ProjectsPage}" Route="projects" />
    </FlyoutItem>

    <FlyoutItem Title="Templates" x:Name="TemplatesFlyoutItem" Icon="nav_projects.png">
        <ShellContent ContentTemplate="{DataTemplate views:TemplatesPage}" Route="templates" />
    </FlyoutItem>

    <FlyoutItem Title="Users" x:Name="UsersFlyoutItem" Icon="nav_profile.png">
        <ShellContent ContentTemplate="{DataTemplate views:UsersPage}" Route="users" />
    </FlyoutItem>

    <FlyoutItem Title="Billing" Icon="nav_profile.png">
        <ShellContent ContentTemplate="{DataTemplate views:BillingPage}" Route="billing" />
    </FlyoutItem>

    <FlyoutItem Title="Profile" Icon="nav_profile.png">
        <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="profile" />
    </FlyoutItem>

</Shell>
