<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             x:Class="TaskManager.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- Soft brand wash -->
        <BoxView Color="{StaticResource CeruleanTint}" HeightRequest="220" VerticalOptions="Start" />

        <ScrollView>
            <VerticalStackLayout Padding="28,48,28,28" Spacing="16">

                <Border WidthRequest="64" HeightRequest="64" StrokeThickness="0"
                        StrokeShape="RoundRectangle 32"
                        BackgroundColor="{StaticResource PrimaryAccent}"
                        HorizontalOptions="Center" Margin="0,12,0,4">
                    <Label Text="TM" TextColor="White" FontSize="22" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <Label Text="TaskManager" Style="{StaticResource BrandMarkLabel}" />
                <Label Text="Sign in to your workspace"
                       Style="{StaticResource SubtitleLabel}"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,8" />

                <Border Style="{StaticResource AppCardBorder}" Padding="20">
                    <VerticalStackLayout Spacing="14">
                        <Entry Placeholder="Username"
                               Text="{Binding Username}"
                               ReturnType="Next" />
                        <Entry Placeholder="Password"
                               Text="{Binding Password}"
                               IsPassword="True"
                               ReturnType="Done" />
                        <Label Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorBanner}"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                        <Button Text="Sign in"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoginCommand}" />
                        <Button Text="Forgot password?"
                                Style="{StaticResource TextButton}"
                                Command="{Binding GoToForgotPasswordCommand}" />
                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,4" />
                        <Label Text="Or continue with SSO" Style="{StaticResource CaptionLabel}" />
                        <Entry Placeholder="Workspace slug"
                               Text="{Binding SsoSlug}" />
                        <Button Text="Sign in with SSO"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding StartSsoCommand}" />
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource PrimaryAccent}"
                                           HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="8" Margin="0,8,0,0">
                    <Button Text="Create a workspace"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding GoToRegisterCommand}" />
                    <Button Text="Accept an invite"
                            Style="{StaticResource TextButton}"
                            Command="{Binding GoToAcceptInviteCommand}"
                            TextColor="{StaticResource TextMuted}" />
                    <Button Text="Have a reset token?"
                            Style="{StaticResource TextButton}"
                            Command="{Binding GoToResetPasswordCommand}"
                            TextColor="{StaticResource TextMuted}"
                            FontSize="13" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
