<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             x:Class="TaskManager.Mobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="14">
            <Label Text="Reset your password" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
            <Label Text="We'll email a reset link if that account exists." TextColor="{StaticResource TextMuted}" />

            <Frame CornerRadius="16" Padding="20" BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource DangerColor}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                    <Label Text="{Binding SuccessMessage}" TextColor="{StaticResource PrimaryAccent}"
                           IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                    <Button Text="Send reset email" Command="{Binding SubmitCommand}"
                            BackgroundColor="{StaticResource PrimaryAccent}" TextColor="{StaticResource PureWhite}"
                            CornerRadius="12" HeightRequest="48" />
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource PrimaryAccent}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
