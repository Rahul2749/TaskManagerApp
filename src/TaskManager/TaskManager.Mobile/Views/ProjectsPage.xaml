<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:controls="clr-namespace:TaskManager.Mobile.Controls"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.ProjectsPage"
             x:DataType="vm:ProjectsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <Grid>
        <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
            <Grid>
                <!-- Skeleton Loader -->
                <VerticalStackLayout Margin="12,6" Spacing="12" IsVisible="{Binding IsBusy}">
                    <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                    <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                    <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                    <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                </VerticalStackLayout>
                
                <CollectionView ItemsSource="{Binding Projects}"
                                IsVisible="{Binding IsNotBusy}"
                                SelectionMode="Single"
                                SelectionChanged="OnProjectSelected">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,60,0,0" Spacing="10">
                            <Label Text="No projects found." FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource TextMuted}" />
                            <Label Text="Tap the + button to create one." FontSize="14" HorizontalOptions="Center" TextColor="{StaticResource TextMuted}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:ProjectDto">
                        <Frame Margin="12,6" Padding="14" CornerRadius="12" BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" HasShadow="False">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Status}" FontSize="13" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding TaskCount, StringFormat='Tasks: {0}'}" FontSize="12" TextColor="{StaticResource PrimaryAccent}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>

        <Button Text="+" 
                Command="{Binding CreateProjectCommand}"
                FontSize="28" 
                FontAttributes="Bold"
                BackgroundColor="{StaticResource PrimaryAccent}" 
                TextColor="White" 
                CornerRadius="28"
                WidthRequest="56" 
                HeightRequest="56"
                HorizontalOptions="End" 
                VerticalOptions="End"
                Margin="24">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Opacity="0.2" Radius="4" />
            </Button.Shadow>
        </Button>
    </Grid>
</ContentPage>

