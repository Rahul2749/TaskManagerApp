<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             x:Class="TaskManager.Mobile.Views.ResetPasswordPage"
             x:DataType="vm:ResetPasswordViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="14">
            <Label Text="Choose a new password" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
            <Label Text="Paste the token from your reset email." TextColor="{StaticResource TextMuted}" />

            <Frame CornerRadius="16" Padding="20" BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Reset token" Text="{Binding Token}" />
                    <Entry Placeholder="New password (min 8)" Text="{Binding Password}" IsPassword="True" />
                    <Entry Placeholder="Confirm password" Text="{Binding ConfirmPassword}" IsPassword="True" />
                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource DangerColor}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                    <Label Text="{Binding SuccessMessage}" TextColor="{StaticResource PrimaryAccent}"
                           IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                    <Button Text="Update password" Command="{Binding SubmitCommand}"
                            BackgroundColor="{StaticResource PrimaryAccent}" TextColor="{StaticResource PureWhite}"
                            CornerRadius="12" HeightRequest="48" />
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource PrimaryAccent}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
