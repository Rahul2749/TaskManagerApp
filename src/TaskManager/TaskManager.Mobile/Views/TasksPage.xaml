<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:controls="clr-namespace:TaskManager.Mobile.Controls"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.TasksPage"
             x:Name="TasksPageRoot"
             x:DataType="vm:TasksViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*" Padding="16,12,16,0">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <controls:AppPageHeader Title="Tasks" Subtitle="Filter and manage your work" />
            <Border Style="{StaticResource FilterBarBorder}">
                <VerticalStackLayout Spacing="8">
                    <Picker Title="Status"
                            ItemsSource="{Binding StatusFilters}"
                            SelectedItem="{Binding SelectedStatusFilter}" />
                    <Picker Title="Project"
                            ItemsSource="{Binding ProjectFilters}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedProjectFilter}" />
                    <Button Text="Clear filters"
                            Style="{StaticResource TextButton}"
                            Command="{Binding ClearFiltersCommand}"
                            HorizontalOptions="Start" />
                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorBanner}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
                <Grid>
                    <VerticalStackLayout Margin="0,8" Spacing="12" IsVisible="{Binding IsBusy}">
                        <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                        <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                        <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding Tasks}"
                                    IsVisible="{Binding IsNotBusy}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnTaskSelected"
                                    ItemSizingStrategy="MeasureFirstItem"
                                    RemainingItemsThreshold="8">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <controls:AppEmptyState Title="No tasks found"
                                                    Message="Try clearing filters or create a new task." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:TaskDto">
                                <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,10" Padding="14">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Title}" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" FontSize="16" />
                                        <Label Text="{Binding ProjectName}" Style="{StaticResource CaptionLabel}" />
                                        <HorizontalStackLayout Spacing="6">
                                            <controls:StatusChip Text="{Binding Status}" Kind="status" />
                                            <controls:StatusChip Text="{Binding Priority}" Kind="priority" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </RefreshView>

            <Button Text="+"
                    Command="{Binding CreateTaskCommand}"
                    FontSize="28"
                    Style="{StaticResource PrimaryButton}"
                    CornerRadius="28"
                    WidthRequest="56"
                    HeightRequest="56"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="16,0,8,20"
                    Padding="0">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource DeepCerulean}" Offset="0,6" Opacity="0.25" Radius="8" />
                </Button.Shadow>
            </Button>
        </Grid>
    </Grid>
</ContentPage>
