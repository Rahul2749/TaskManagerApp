<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:controls="clr-namespace:TaskManager.Mobile.Controls"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.CalendarPage"
             x:Name="CalendarRoot"
             x:DataType="vm:CalendarViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="12">
                <controls:AppPageHeader Title="Calendar" Subtitle="Due dates by month" />

                <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorBanner}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

                <controls:FeatureLockedView Message="{Binding UpgradeMessage}"
                                            UpgradeCommand="{Binding GoToBillingCommand}"
                                            IsVisible="{Binding HasAccess, Converter={StaticResource InvertedBoolConverter}}" />

                <VerticalStackLayout IsVisible="{Binding HasAccess}" Spacing="12">
                    <Border Style="{StaticResource FilterBarBorder}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0" Text="‹" Style="{StaticResource IconButton}"
                                    Command="{Binding PreviousMonthCommand}" />
                            <Label Grid.Column="1" Text="{Binding MonthLabel}" Style="{StaticResource SectionTitleLabel}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                            <Button Grid.Column="2" Text="›" Style="{StaticResource IconButton}"
                                    Command="{Binding NextMonthCommand}" />
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,*,*,*,*,*,*" Margin="0,4,0,0">
                        <Label Grid.Column="0" Text="S" HorizontalOptions="Center" Style="{StaticResource CaptionLabel}" />
                        <Label Grid.Column="1" Text="M" HorizontalOptions="Center" Style="{StaticResource CaptionLabel}" />
                        <Label Grid.Column="2" Text="T" HorizontalOptions="Center" Style="{StaticResource CaptionLabel}" />
                        <Label Grid.Column="3" Text="W" HorizontalOptions="Center" Style="{StaticResource CaptionLabel}" />
                        <Label Grid.Column="4" Text="T" HorizontalOptions="Center" Style="{StaticResource CaptionLabel}" />
                        <Label Grid.Column="5" Text="F" HorizontalOptions="Center" Style="{StaticResource CaptionLabel}" />
                        <Label Grid.Column="6" Text="S" HorizontalOptions="Center" Style="{StaticResource CaptionLabel}" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Days}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="7" HorizontalItemSpacing="4" VerticalItemSpacing="4" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:CalendarDayCell">
                                <Border Stroke="{StaticResource BorderColor}" StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                        Padding="4" HeightRequest="56"
                                        BackgroundColor="{StaticResource CardBackground}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference CalendarRoot}, Path=BindingContext.SelectDayCellCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout>
                                        <Label Text="{Binding DayNumber}" FontSize="13" HorizontalOptions="Center"
                                               TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="{Binding CountLabel}" FontSize="11" HorizontalOptions="Center"
                                               TextColor="{StaticResource PrimaryAccent}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{Binding SelectedDayLabel}" Style="{StaticResource SectionTitleLabel}" Margin="0,8,0,0" />
                    <CollectionView ItemsSource="{Binding SelectedDayTasks}" SelectionMode="None" HeightRequest="220">
                        <CollectionView.EmptyView>
                            <controls:AppEmptyState Title="No tasks due"
                                                    Message="Pick another day or add due dates to tasks." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:TaskDto">
                                <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference CalendarRoot}, Path=BindingContext.OpenTaskCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                        <HorizontalStackLayout Spacing="6">
                                            <controls:StatusChip Text="{Binding Status}" Kind="status" />
                                            <controls:StatusChip Text="{Binding Priority}" Kind="priority" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
