<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:controls="clr-namespace:TaskManager.Mobile.Controls"
             xmlns:billing="clr-namespace:TaskManager.Shared.DTOs.Billing;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.BillingPage"
             x:DataType="vm:BillingViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="14">
                <controls:AppPageHeader Title="Billing" Subtitle="Plan, features, and invoices" />

                <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorBanner}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

                <Border Style="{StaticResource AppCardBorder}" Padding="18">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding PlanName}" Style="{StaticResource TitleLabel}" FontSize="22" />
                        <Label Text="{Binding PlanCode, StringFormat='Code: {0}'}" Style="{StaticResource CaptionLabel}" />
                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource CeruleanTint}" Padding="10,4"
                                HorizontalOptions="Start">
                            <Label Text="{Binding Status}" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource DeepCerulean}" />
                        </Border>
                        <Label Text="{Binding SeatsLabel}" Style="{StaticResource BodyLabel}" Margin="0,4,0,0" />
                        <Label Text="{Binding PeriodLabel}" Style="{StaticResource CaptionLabel}"
                               IsVisible="{Binding PeriodLabel, Converter={StaticResource StringNotEmptyConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding UpgradeHint}" Style="{StaticResource SubtitleLabel}" />

                <Button Text="Manage billing on web"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding OpenWebBillingCommand}" />
                <Button Text="View pricing"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding OpenWebPricingCommand}" />

                <Label Text="Included features" Style="{StaticResource SectionTitleLabel}" Margin="0,8,0,0" />
                <Border Style="{StaticResource AppCardBorder}" Padding="14">
                    <CollectionView ItemsSource="{Binding FeatureList}" HeightRequest="160" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Label Text="{Binding ., StringFormat='• {0}'}" Margin="0,2" Style="{StaticResource BodyLabel}"
                                       TextColor="{StaticResource TextSecondary}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <VerticalStackLayout IsVisible="{Binding CanManageBilling}" Spacing="8">
                    <Label Text="Recent invoices" Style="{StaticResource SectionTitleLabel}" />
                    <CollectionView ItemsSource="{Binding Invoices}" HeightRequest="200" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <controls:AppEmptyState Title="No invoices yet"
                                                    Message="Paid invoices will appear here." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="billing:InvoiceDto">
                                <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="12">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Number}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="{Binding Amount, StringFormat='{0:N2}'}" Style="{StaticResource BodyLabel}" />
                                        <Label Text="{Binding Status}" Style="{StaticResource CaptionLabel}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
