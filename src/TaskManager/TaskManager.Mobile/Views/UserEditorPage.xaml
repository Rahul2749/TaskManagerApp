<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             x:Class="TaskManager.Mobile.Views.UserEditorPage"
             x:DataType="vm:UserEditorViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="First Name" TextColor="{StaticResource TextSecondary}" FontSize="14" />
            <Entry Text="{Binding FirstName}" Placeholder="John" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" />

            <Label Text="Last Name" TextColor="{StaticResource TextSecondary}" FontSize="14" />
            <Entry Text="{Binding LastName}" Placeholder="Doe" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" />

            <Label Text="Username" TextColor="{StaticResource TextSecondary}" FontSize="14" />
            <Entry Text="{Binding Username}" Placeholder="johndoe" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" />

            <Label Text="Email" TextColor="{StaticResource TextSecondary}" FontSize="14" />
            <Entry Text="{Binding Email}" Placeholder="john@example.com" Keyboard="Email" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" />

            <Label Text="Password" TextColor="{StaticResource TextSecondary}" FontSize="14" />
            <Entry Text="{Binding Password}" IsPassword="True" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}">
                <Entry.Triggers>
                    <DataTrigger TargetType="Entry" Binding="{Binding IsEditing}" Value="True">
                        <Setter Property="Placeholder" Value="Leave blank to keep same" />
                    </DataTrigger>
                    <DataTrigger TargetType="Entry" Binding="{Binding IsEditing}" Value="False">
                        <Setter Property="Placeholder" Value="Enter a new password" />
                    </DataTrigger>
                </Entry.Triggers>
            </Entry>

            <Label Text="Role" TextColor="{StaticResource TextSecondary}" FontSize="14" />
            <Picker ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" TextColor="{StaticResource TextPrimary}" Title="Select Role" />

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource DangerColor}" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <Button Text="Save User" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource PrimaryAccent}" TextColor="White" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0" />
            <Button Text="Deactivate User" Command="{Binding DeleteCommand}" BackgroundColor="{StaticResource DangerColor}" TextColor="White" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0" IsVisible="{Binding IsEditing}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource PrimaryAccent}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
