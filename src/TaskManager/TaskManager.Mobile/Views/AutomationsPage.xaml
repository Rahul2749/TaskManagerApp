<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:controls="clr-namespace:TaskManager.Mobile.Controls"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.AutomationsPage"
             x:DataType="vm:AutomationsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="12">
                <controls:AppPageHeader Title="Automations"
                                        Subtitle="Read-only view — create and edit rules on the web" />
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorBanner}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                <controls:FeatureLockedView Message="{Binding UpgradeMessage}"
                                            UpgradeCommand="{Binding GoToBillingCommand}"
                                            IsVisible="{Binding HasAccess, Converter={StaticResource InvertedBoolConverter}}" />

                <CollectionView ItemsSource="{Binding Rules}" IsVisible="{Binding HasAccess}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <controls:AppEmptyState Title="No rules yet"
                                                Message="Admins can create automations on the web app." />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:AutomationRuleDto">
                            <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding IsEnabled, Converter={StaticResource BoolToCheckMarkConverter}}"
                                               TextColor="{StaticResource SuccessColor}" />
                                    </Grid>
                                    <Label Text="{Binding TriggerType, StringFormat='When: {0}'}" Style="{StaticResource CaptionLabel}" />
                                    <Label Text="{Binding ActionType, StringFormat='Then: {0}'}" Style="{StaticResource CaptionLabel}" />
                                    <Label Text="{Binding LastRunAt, StringFormat='Last run: {0:g}'}" Style="{StaticResource CaptionLabel}"
                                           IsVisible="{Binding LastRunAt, Converter={StaticResource IsNotNullConverter}}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
