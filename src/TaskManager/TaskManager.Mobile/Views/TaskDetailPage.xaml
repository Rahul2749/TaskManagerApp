<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:controls="clr-namespace:TaskManager.Mobile.Controls"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.TaskDetailPage"
             x:Name="TaskDetailRoot"
             x:DataType="vm:TaskDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Share" Command="{Binding ShareCommand}" />
        <ToolbarItem Text="Edit" Command="{Binding EditCommand}" />
        <ToolbarItem Text="Delete" Command="{Binding DeleteCommand}" />
    </ContentPage.ToolbarItems>

    <Grid>
        <VerticalStackLayout Padding="20" Spacing="16" IsVisible="{Binding IsBusy}">
            <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
            <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
            <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
        </VerticalStackLayout>

        <ScrollView IsVisible="{Binding IsNotBusy}">
            <VerticalStackLayout Padding="20" Spacing="14">
                <controls:AppPageHeader Title="{Binding TaskTitle}" Subtitle="{Binding ProjectName}" />
                <Label Text="{Binding Description}" Style="{StaticResource BodyLabel}" />

                <Border Style="{StaticResource AppCardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Status" Style="{StaticResource CaptionLabel}" />
                        <Picker Title="Select status"
                                ItemsSource="{Binding StatusOptions}"
                                SelectedItem="{Binding Status}" />
                        <HorizontalStackLayout Spacing="8">
                            <controls:StatusChip Text="{Binding Priority}" Kind="priority" />
                            <Label Text="{Binding DueDate, StringFormat='Due {0:d}'}" Style="{StaticResource CaptionLabel}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Button Text="Update status" Style="{StaticResource PrimaryButton}"
                                Command="{Binding UpdateStatusCommand}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding SuccessMessage}" Style="{StaticResource SuccessBanner}"
                       IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorBanner}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

                <!-- Time tracking -->
                <VerticalStackLayout IsVisible="{Binding HasTimeTracking}" Spacing="8">
                    <Label Text="Time tracking" Style="{StaticResource SectionTitleLabel}" Margin="0,8,0,0" />
                    <Label Text="{Binding ActualHours, StringFormat='Actual: {0:0.##} h'}" Style="{StaticResource CaptionLabel}" />
                    <Border Style="{StaticResource AppCardBorder}">
                        <VerticalStackLayout Spacing="8">
                            <Entry Placeholder="Hours (e.g. 1.5)" Text="{Binding LogHoursText}" Keyboard="Numeric" />
                            <Entry Placeholder="Notes" Text="{Binding LogNotes}" />
                            <Button Text="Log time" Style="{StaticResource GhostButton}" Command="{Binding LogTimeCommand}" />
                        </VerticalStackLayout>
                    </Border>
                    <CollectionView ItemsSource="{Binding TimeEntries}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No time logged yet." Style="{StaticResource CaptionLabel}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:TimeEntryDto">
                                <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Hours, StringFormat='{0:0.##} h'}" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding WorkDate, StringFormat='{0:MMM d}'}" Style="{StaticResource CaptionLabel}" />
                                            <Label Text="{Binding Notes}" Style="{StaticResource CaptionLabel}"
                                                   IsVisible="{Binding Notes, Converter={StaticResource StringNotEmptyConverter}}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="✕" Style="{StaticResource IconButton}"
                                                Command="{Binding Source={x:Reference TaskDetailRoot}, Path=BindingContext.DeleteTimeEntryCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Dependencies -->
                <VerticalStackLayout IsVisible="{Binding HasGantt}" Spacing="8">
                    <Label Text="Dependencies" Style="{StaticResource SectionTitleLabel}" Margin="0,8,0,0" />
                    <VerticalStackLayout IsVisible="{Binding CanManageAdvanced}" Spacing="8">
                        <Picker Title="Predecessor blocks this task"
                                ItemsSource="{Binding ProjectTasks}"
                                ItemDisplayBinding="{Binding Title}"
                                SelectedItem="{Binding SelectedPredecessor}" />
                        <Button Text="Add dependency" Style="{StaticResource GhostButton}"
                                Command="{Binding AddDependencyCommand}" />
                    </VerticalStackLayout>
                    <CollectionView ItemsSource="{Binding Dependencies}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No dependencies." Style="{StaticResource CaptionLabel}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:TaskDependencyDto">
                                <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding PredecessorTitle, StringFormat='{0} → this'}"
                                               TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                        <Button Grid.Column="1" Text="✕" Style="{StaticResource IconButton}"
                                                Command="{Binding Source={x:Reference TaskDetailRoot}, Path=BindingContext.RemoveDependencyCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Recurrence -->
                <VerticalStackLayout IsVisible="{Binding CanManageAdvanced}" Spacing="8">
                    <Label Text="Recurrence" Style="{StaticResource SectionTitleLabel}" Margin="0,8,0,0" />
                    <Border Style="{StaticResource AppCardBorder}">
                        <VerticalStackLayout Spacing="8">
                            <Picker Title="Frequency"
                                    ItemsSource="{Binding RecurrenceOptions}"
                                    SelectedItem="{Binding RecurrenceFrequency}" />
                            <Entry Placeholder="Interval (every N)" Text="{Binding RecurrenceIntervalText}" Keyboard="Numeric" />
                            <Label Text="{Binding NextOccurrenceLabel}" Style="{StaticResource CaptionLabel}"
                                   IsVisible="{Binding NextOccurrenceLabel, Converter={StaticResource StringNotEmptyConverter}}" />
                            <Button Text="Save recurrence" Style="{StaticResource GhostButton}"
                                    Command="{Binding SaveRecurrenceCommand}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Checklist -->
                <HorizontalStackLayout Margin="0,8,0,4">
                    <Label Text="Checklist" Style="{StaticResource SectionTitleLabel}" HorizontalOptions="StartAndExpand" />
                    <Label Text="{Binding SubtaskProgress}" Style="{StaticResource CaptionLabel}" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <CollectionView ItemsSource="{Binding Subtasks}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No checklist items yet." Style="{StaticResource CaptionLabel}" Margin="4" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:SubtaskDto">
                            <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="10">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Button Grid.Column="0"
                                            Text="{Binding IsCompleted, Converter={StaticResource BoolToCheckMarkConverter}}"
                                            Style="{StaticResource IconButton}"
                                            FontSize="18"
                                            Command="{Binding Source={x:Reference TaskDetailRoot}, Path=BindingContext.ToggleSubtaskCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Label Grid.Column="1" Text="{Binding Title}" TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" LineBreakMode="WordWrap" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout IsVisible="{Binding CanCreateSubtasks}" Spacing="8">
                    <Entry Placeholder="New checklist item" Text="{Binding NewSubtaskTitle}" />
                    <Button Text="Add item" Style="{StaticResource GhostButton}" Command="{Binding AddSubtaskCommand}" />
                </VerticalStackLayout>

                <!-- Comments -->
                <Label Text="Comments" Style="{StaticResource SectionTitleLabel}" Margin="0,8,0,4" />
                <Label Text="Tip: mention teammates with @username" Style="{StaticResource CaptionLabel}" />

                <CollectionView ItemsSource="{Binding Comments}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No comments yet." Style="{StaticResource CaptionLabel}" Margin="4" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:CommentDto">
                            <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="12">
                                <VerticalStackLayout Spacing="4">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Author.FullName}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:MMM dd HH:mm}'}" Style="{StaticResource CaptionLabel}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Body}" Style="{StaticResource BodyLabel}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Editor Placeholder="Write a comment…" Text="{Binding NewComment}" AutoSize="TextChanges" HeightRequest="80" />
                <Button Text="Post comment" Style="{StaticResource PrimaryButton}" Command="{Binding AddCommentCommand}" />

                <!-- History -->
                <Label Text="Task history" Style="{StaticResource SectionTitleLabel}" Margin="0,8,0,8" />
                <CollectionView ItemsSource="{Binding History}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No history available." Style="{StaticResource CaptionLabel}" Margin="10" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:TaskHistoryDto">
                            <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="12">
                                <VerticalStackLayout Spacing="4">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding ChangedBy.FullName}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="{Binding ChangedAt, StringFormat='{0:MMM dd, yyyy HH:mm}'}" Style="{StaticResource CaptionLabel}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding FieldName, StringFormat='Changed {0}'}" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                    <Label FontSize="12" TextColor="{StaticResource TextMuted}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding OldValue}" />
                                                <Span Text=" → " />
                                                <Span Text="{Binding NewValue}" FontAttributes="Bold" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
