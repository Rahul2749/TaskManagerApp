<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">

                <Label Text="{Binding WelcomeText}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                    <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="14" Padding="14" HasShadow="False">
                        <VerticalStackLayout>
                            <Label Text="Total tasks" FontSize="12" TextColor="{StaticResource TextMuted}" />
                            <Label Text="{Binding TotalTasks}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource PrimaryAccent}" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="14" Padding="14" HasShadow="False">
                        <VerticalStackLayout>
                            <Label Text="Completed" FontSize="12" TextColor="{StaticResource TextMuted}" />
                            <Label Text="{Binding CompletedTasks}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource SuccessColor}" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="14" Padding="14" HasShadow="False">
                        <VerticalStackLayout>
                            <Label Text="In progress" FontSize="12" TextColor="{StaticResource TextMuted}" />
                            <Label Text="{Binding InProgressTasks}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource WarningColor}" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="14" Padding="14" HasShadow="False">
                        <VerticalStackLayout>
                            <Label Text="Overdue" FontSize="12" TextColor="{StaticResource TextMuted}" />
                            <Label Text="{Binding OverdueTasks}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource DangerColor}" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Label Text="Recent tasks" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />

                <CollectionView ItemsSource="{Binding RecentTasks}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:TaskDto">
                            <Frame Margin="0,4" Padding="14" CornerRadius="12" BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" HasShadow="False">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Status}" FontSize="13" TextColor="{StaticResource TextMuted}" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource DangerColor}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>

