<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:controls="clr-namespace:TaskManager.Mobile.Controls"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <Grid>
            <VerticalStackLayout Padding="20" Spacing="16" IsVisible="{Binding IsBusy}">
                <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
                <controls:SkeletonCard IsLoading="{Binding IsBusy}" />
            </VerticalStackLayout>

            <ScrollView IsVisible="{Binding IsNotBusy}">
                <VerticalStackLayout Padding="20" Spacing="16">

                    <controls:AppPageHeader Title="{Binding WelcomeText}"
                                            Subtitle="Here's what's happening in your workspace" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <controls:AppStatCard Grid.Row="0" Grid.Column="0"
                                              Label="Total tasks"
                                              Value="{Binding TotalTasks, StringFormat='{0}'}"
                                              Accent="primary" />
                        <controls:AppStatCard Grid.Row="0" Grid.Column="1"
                                              Label="Completed"
                                              Value="{Binding CompletedTasks, StringFormat='{0}'}"
                                              Accent="success" />
                        <controls:AppStatCard Grid.Row="1" Grid.Column="0"
                                              Label="In progress"
                                              Value="{Binding InProgressTasks, StringFormat='{0}'}"
                                              Accent="warning" />
                        <controls:AppStatCard Grid.Row="1" Grid.Column="1"
                                              Label="Overdue"
                                              Value="{Binding OverdueTasks, StringFormat='{0}'}"
                                              Accent="danger" />
                    </Grid>

                    <Label Text="Upcoming deadlines" Style="{StaticResource SectionTitleLabel}" />
                    <CollectionView ItemsSource="{Binding UpcomingDeadlines}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <controls:AppEmptyState Title="No upcoming deadlines"
                                                    Message="Tasks with due dates will show up here." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:TaskDto">
                                <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="14">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding DueDate, StringFormat='Due {0:MMM dd}'}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="{StaticResource DangerColor}" />
                                            <Label Text="{Binding ProjectName}" Style="{StaticResource CaptionLabel}" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="6">
                                            <controls:StatusChip Text="{Binding Status}" Kind="status" />
                                            <controls:StatusChip Text="{Binding Priority}" Kind="priority" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Project progress" Style="{StaticResource SectionTitleLabel}" Margin="0,4,0,0" />
                    <CollectionView ItemsSource="{Binding ProjectSummaries}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <controls:AppEmptyState Title="No active projects"
                                                    Message="Create a project to track progress." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:ProjectTaskSummary">
                                <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="14">
                                    <VerticalStackLayout Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="{Binding ProjectName}" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CompletionPercentage, StringFormat='{0}%'}"
                                                   FontAttributes="Bold" TextColor="{StaticResource PrimaryAccent}" />
                                        </Grid>
                                        <ProgressBar Progress="{Binding CompletionPercentage, Converter={StaticResource DivideByHundredConverter}}"
                                                     ProgressColor="{StaticResource PrimaryAccent}"
                                                     BackgroundColor="{StaticResource IceBlue}"
                                                     HeightRequest="8" />
                                        <HorizontalStackLayout Spacing="12">
                                            <Label Text="{Binding TotalTasks, StringFormat='Total {0}'}" Style="{StaticResource CaptionLabel}" />
                                            <Label Text="{Binding CompletedTasks, StringFormat='Done {0}'}" Style="{StaticResource CaptionLabel}"
                                                   TextColor="{StaticResource SuccessColor}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Recent tasks" Style="{StaticResource SectionTitleLabel}" Margin="0,4,0,0" />
                    <CollectionView ItemsSource="{Binding RecentTasks}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <controls:AppEmptyState Title="No recent tasks" Message="New work will appear here." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:TaskDto">
                                <Border Style="{StaticResource AppCardBorder}" Margin="0,0,0,8" Padding="14">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                        <HorizontalStackLayout Spacing="6">
                                            <controls:StatusChip Text="{Binding Status}" Kind="status" />
                                            <controls:StatusChip Text="{Binding Priority}" Kind="priority" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorBanner}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </RefreshView>
</ContentPage>
