<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.NotificationsPage"
             x:Name="NotificationsRoot"
             x:DataType="vm:NotificationsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Mark all read" Command="{Binding MarkAllReadCommand}" />
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <Grid>
            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None" IsVisible="{Binding IsNotBusy}">
                <CollectionView.EmptyView>
                    <Label Text="You're all caught up." HorizontalOptions="Center" Margin="0,40"
                           TextColor="{StaticResource TextMuted}" />
                </CollectionView.EmptyView>
                <CollectionView.Header>
                    <VerticalStackLayout Padding="16,12,16,0" Spacing="4">
                        <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource DangerColor}"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                        <Label Text="{Binding SuccessMessage}" TextColor="{StaticResource PrimaryAccent}"
                               IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                    </VerticalStackLayout>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:AppNotificationDto">
                        <Frame Margin="12,6" Padding="14" CornerRadius="12"
                               BackgroundColor="{StaticResource CardBackground}"
                               BorderColor="{StaticResource BorderColor}" HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference NotificationsRoot}, Path=BindingContext.OpenCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Message}" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding CreatedAt, StringFormat='{0:g}'}" FontSize="12" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryAccent}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>
    </RefreshView>
</ContentPage>
