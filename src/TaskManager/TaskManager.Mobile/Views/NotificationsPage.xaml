<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:controls="clr-namespace:TaskManager.Mobile.Controls"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.NotificationsPage"
             x:Name="NotificationsRoot"
             x:DataType="vm:NotificationsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Mark all read" Command="{Binding MarkAllReadCommand}" />
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <Grid>
            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None" IsVisible="{Binding IsNotBusy}">
                <CollectionView.EmptyView>
                    <controls:AppEmptyState Title="You're all caught up"
                                            Message="New mentions and updates will appear here." />
                </CollectionView.EmptyView>
                <CollectionView.Header>
                    <VerticalStackLayout Padding="16,12,16,8" Spacing="8">
                        <controls:AppPageHeader Title="Notifications" Subtitle="Mentions and updates" />
                        <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorBanner}"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                        <Label Text="{Binding SuccessMessage}" Style="{StaticResource SuccessBanner}"
                               IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                    </VerticalStackLayout>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:AppNotificationDto">
                        <Border Style="{StaticResource AppCardBorder}" Margin="16,0,16,10" Padding="14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference NotificationsRoot}, Path=BindingContext.OpenCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Message}" FontSize="14"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding CreatedAt, StringFormat='{0:g}'}" Style="{StaticResource CaptionLabel}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryAccent}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>
    </RefreshView>
</ContentPage>
