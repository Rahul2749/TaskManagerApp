<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             x:Class="TaskManager.Mobile.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <VerticalStackLayout Padding="24" Spacing="16">
        <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="16" Padding="20" HasShadow="False">
            <VerticalStackLayout Spacing="8">
                <Label Text="{Binding User.FullName}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                <Label Text="{Binding User.Email}" TextColor="{StaticResource TextMuted}" />
                <Label Text="{Binding RoleDisplay, StringFormat='Role: {0}'}" TextColor="{StaticResource PrimaryAccent}" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Frame>

        <Button Text="Logout"
                Command="{Binding LogoutCommand}"
                BackgroundColor="{StaticResource DangerColor}"
                TextColor="{StaticResource PureWhite}"
                CornerRadius="12"
                HeightRequest="48" />
    </VerticalStackLayout>
</ContentPage>

