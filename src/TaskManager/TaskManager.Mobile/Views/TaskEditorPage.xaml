<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             xmlns:dto="clr-namespace:TaskManager.Shared.DTOs;assembly=TaskManager.Shared"
             x:Class="TaskManager.Mobile.Views.TaskEditorPage"
             x:DataType="vm:TaskEditorViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="12" Padding="16" HasShadow="False">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Task Details" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" FontSize="18" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Title *" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <Entry Text="{Binding TaskTitle}" Placeholder="Enter task title" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Description" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <Editor Text="{Binding Description}" Placeholder="Enter description" HeightRequest="100" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" AutoSize="TextChanges" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Priority" TextColor="{StaticResource TextMuted}" FontSize="14" />
                            <Picker ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding Priority}" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Status" TextColor="{StaticResource TextMuted}" FontSize="14" />
                            <Picker ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Due Date" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <DatePicker Date="{Binding DueDate}" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="12" Padding="16" HasShadow="False" IsVisible="{Binding CanAssignProjects}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Assignment" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" FontSize="18" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Project *" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <Picker ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}" ItemDisplayBinding="{Binding Name}" Title="Select Project" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Assign To" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <Picker ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" ItemDisplayBinding="{Binding Username}" Title="Unassigned" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource DangerColor}" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <Button Text="Save Task" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource PrimaryAccent}" TextColor="White" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource PrimaryAccent}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
