<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskManager.Mobile.ViewModels"
             x:Class="TaskManager.Mobile.Views.ProjectEditorPage"
             x:DataType="vm:ProjectEditorViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="12" Padding="16" HasShadow="False">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Project Details" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" FontSize="18" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Name *" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <Entry Text="{Binding ProjectName}" Placeholder="Enter project name" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Description" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <Editor Text="{Binding Description}" Placeholder="Enter description" HeightRequest="100" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" AutoSize="TextChanges" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Status" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <Picker ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Start Date" TextColor="{StaticResource TextMuted}" FontSize="14" />
                            <DatePicker Date="{Binding StartDate}" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="End Date" TextColor="{StaticResource TextMuted}" FontSize="14" />
                            <DatePicker Date="{Binding EndDate}" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource BorderColor}" CornerRadius="12" Padding="16" HasShadow="False" IsVisible="{Binding CanAssignManager}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Management" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" FontSize="18" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Project Manager" TextColor="{StaticResource TextMuted}" FontSize="14" />
                        <Picker ItemsSource="{Binding Managers}" SelectedItem="{Binding SelectedManager}" ItemDisplayBinding="{Binding Username}" Title="Unassigned" BackgroundColor="{StaticResource AppBackground}" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource DangerColor}" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <Button Text="Save Project" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource PrimaryAccent}" TextColor="White" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0" />
            <Button Text="Delete Project" Command="{Binding DeleteCommand}" BackgroundColor="{StaticResource DangerColor}" TextColor="White" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0" IsVisible="{Binding ProjectId, Converter={x:StaticResource IntGreaterThanZeroConverter}}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource PrimaryAccent}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
