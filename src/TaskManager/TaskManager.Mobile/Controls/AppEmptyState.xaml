<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TaskManager.Mobile.Controls.AppEmptyState"
             x:Name="Root">

    <Border Style="{StaticResource AppCardBorder}" Margin="0,24" Padding="24">
        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
            <Border WidthRequest="48" HeightRequest="48" StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    BackgroundColor="{StaticResource CeruleanTint}"
                    HorizontalOptions="Center">
                <Label Text="◇" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{StaticResource DeepCerulean}" />
            </Border>
            <Label Text="{Binding Title, Source={x:Reference Root}}"
                   Style="{StaticResource SectionTitleLabel}"
                   HorizontalTextAlignment="Center" />
            <Label Text="{Binding Message, Source={x:Reference Root}}"
                   Style="{StaticResource CaptionLabel}"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding Message, Source={x:Reference Root}, Converter={StaticResource StringNotEmptyConverter}}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
