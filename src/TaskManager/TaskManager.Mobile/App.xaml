<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:TaskManager.Mobile.Converters"
             x:Class="TaskManager.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <conv:IntGreaterThanZeroConverter x:Key="IntGreaterThanZeroConverter" />
            <conv:DivideByHundredConverter x:Key="DivideByHundredConverter" />
            <conv:BoolToCheckMarkConverter x:Key="BoolToCheckMarkConverter" />
            <conv:IsNotNullConverter x:Key="IsNotNullConverter" />
            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <conv:StatusToChipBackgroundConverter x:Key="StatusToChipBackgroundConverter" />
            <conv:StatusToChipTextConverter x:Key="StatusToChipTextConverter" />
            <conv:PriorityToChipBackgroundConverter x:Key="PriorityToChipBackgroundConverter" />
            <conv:PriorityToChipTextConverter x:Key="PriorityToChipTextConverter" />

            <!-- Coastal professional palette -->
            <Color x:Key="SoftestFrost">#F7FAFB</Color>
            <Color x:Key="PureWhite">#FFFFFF</Color>
            <Color x:Key="IceBlue">#E6F0F2</Color>
            <Color x:Key="DeeperIce">#D9E8EB</Color>
            <Color x:Key="DeepestSlate">#1A2B36</Color>
            <Color x:Key="SlateGray">#314757</Color>
            <Color x:Key="MutedSlate">#668091</Color>
            <Color x:Key="SlateTint">#CBDDE5</Color>
            <Color x:Key="SoftCerulean">#75ABD3</Color>
            <Color x:Key="DeepCerulean">#5A94BE</Color>
            <Color x:Key="CeruleanTint">#EAF4FB</Color>
            <Color x:Key="DeepMint">#98C4B5</Color>
            <Color x:Key="PaleMint">#CDE2DB</Color>
            <Color x:Key="SoftPeach">#D8B4A0</Color>
            <Color x:Key="BlushPink">#FCE9EE</Color>
            <Color x:Key="DeepPeach">#C49B85</Color>
            <Color x:Key="PeachTint">#F2E5DD</Color>
            <Color x:Key="Lavender">#9E97C9</Color>
            <Color x:Key="PaleLavender">#E8E5F2</Color>
            <Color x:Key="SageGreen">#B6C99B</Color>
            <Color x:Key="Transparent">Transparent</Color>

            <Color x:Key="AppBackground">#F4F7F9</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="TextPrimary">#1A2B36</Color>
            <Color x:Key="TextSecondary">#314757</Color>
            <Color x:Key="TextMuted">#668091</Color>
            <Color x:Key="BorderColor">#D5E3EA</Color>
            <Color x:Key="PrimaryAccent">#5A94BE</Color>
            <Color x:Key="SuccessColor">#4F8F7A</Color>
            <Color x:Key="WarningColor">#C49B85</Color>
            <Color x:Key="DangerColor">#C47A7A</Color>
            <Color x:Key="BannerErrorBg">#FCE9EE</Color>
            <Color x:Key="BannerSuccessBg">#CDE2DB</Color>
            <Color x:Key="BannerInfoBg">#EAF4FB</Color>

            <!-- Spacing tokens (use as Thickness / numbers in styles) -->
            <x:Double x:Key="SpaceXs">4</x:Double>
            <x:Double x:Key="SpaceSm">8</x:Double>
            <x:Double x:Key="SpaceMd">12</x:Double>
            <x:Double x:Key="SpaceLg">16</x:Double>
            <x:Double x:Key="SpaceXl">24</x:Double>
            <x:Double x:Key="RadiusSm">8</x:Double>
            <x:Double x:Key="RadiusMd">12</x:Double>
            <x:Double x:Key="RadiusLg">16</x:Double>
            <x:Double x:Key="RadiusPill">20</x:Double>

            <!-- Typography -->
            <Style x:Key="TitleLabel" TargetType="Label">
                <Setter Property="FontSize" Value="26" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="LineBreakMode" Value="TailTruncation" />
            </Style>
            <Style x:Key="SectionTitleLabel" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>
            <Style x:Key="SubtitleLabel" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
            </Style>
            <Style x:Key="BodyLabel" TargetType="Label">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>
            <Style x:Key="CaptionLabel" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
            </Style>
            <Style x:Key="BrandMarkLabel" TargetType="Label">
                <Setter Property="FontSize" Value="34" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>

            <!-- Cards -->
            <Style x:Key="AppCardBorder" TargetType="Border">
                <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 16" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="Padding" Value="16" />
            </Style>
            <Style x:Key="FilterBarBorder" TargetType="Border">
                <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <!-- Buttons -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryAccent}" />
                <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="Padding" Value="16,0" />
            </Style>
            <Style x:Key="GhostButton" TargetType="Button">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryAccent}" />
                <Setter Property="BorderColor" Value="{StaticResource PrimaryAccent}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="44" />
            </Style>
            <Style x:Key="TextButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryAccent}" />
                <Setter Property="FontAttributes" Value="None" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="Padding" Value="0" />
            </Style>
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BackgroundColor" Value="{StaticResource DangerColor}" />
                <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>
            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BackgroundColor" Value="{StaticResource IceBlue}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="WidthRequest" Value="40" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <!-- Default control styles -->
            <Style TargetType="Frame">
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="HasShadow" Value="False" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryAccent}" />
                <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>
            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BackgroundColor" Value="{StaticResource IceBlue}" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>
            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BackgroundColor" Value="{StaticResource IceBlue}" />
            </Style>
            <Style TargetType="Picker">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="TitleColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BackgroundColor" Value="{StaticResource IceBlue}" />
            </Style>
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource AppBackground}" />
            </Style>

            <!-- Message banners -->
            <Style x:Key="ErrorBanner" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource DangerColor}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="BackgroundColor" Value="{StaticResource BannerErrorBg}" />
            </Style>
            <Style x:Key="SuccessBanner" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource SuccessColor}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="BackgroundColor" Value="{StaticResource BannerSuccessBg}" />
            </Style>
            <Style x:Key="InfoBanner" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource DeepCerulean}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="BackgroundColor" Value="{StaticResource BannerInfoBg}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
