<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:TaskManager.Mobile.Converters"
             x:Class="TaskManager.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            
            <!-- Organic Rustic Palette -->
            <Color x:Key="DeepCharcoal">#1F2328</Color>
            <Color x:Key="DarkWenge">#362D26</Color>
            <Color x:Key="DeepForest">#3C4A3F</Color>
            <Color x:Key="DarkOlive">#4A4C39</Color>
            <Color x:Key="MutedMoss">#808B7A</Color>
            <Color x:Key="MutedSage">#A9B7A6</Color>
            <Color x:Key="Eucalyptus">#BFC9B8</Color>
            <Color x:Key="GhostSage">#D1D9CD</Color>
            <Color x:Key="IvoryCream">#FAF5EB</Color>
            <Color x:Key="AlmondBeige">#E7E2D9</Color>
            <Color x:Key="WarmLinen">#DCD5CB</Color>
            <Color x:Key="DriedOat">#BFB5A2</Color>
            <Color x:Key="PureWhite">#FFFFFF</Color>
            <Color x:Key="GoldenOchre">#B3925F</Color>
            <Color x:Key="DeepRust">#A96142</Color>
            <Color x:Key="Terracotta">#C97C5D</Color>
            <Color x:Key="ClayRed">#94534F</Color>
            <Color x:Key="Transparent">Transparent</Color>
            
            <!-- Semantic Mappings -->
            <Color x:Key="AppBackground">#FAF5EB</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="TextPrimary">#1F2328</Color>
            <Color x:Key="TextSecondary">#362D26</Color>
            <Color x:Key="TextMuted">#808B7A</Color>
            <Color x:Key="BorderColor">#DCD5CB</Color>
            
            <Color x:Key="PrimaryAccent">#C97C5D</Color>
            <Color x:Key="SuccessColor">#808B7A</Color>
            <Color x:Key="WarningColor">#B3925F</Color>
            <Color x:Key="DangerColor">#94534F</Color>
            
            <!-- Global Component Styles -->
            <Style TargetType="Frame">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="HasShadow" Value="False" />
            </Style>
            
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryAccent}" />
                <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
