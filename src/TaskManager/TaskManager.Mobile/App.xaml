<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:TaskManager.Mobile.Converters"
             x:Class="TaskManager.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            
            <!-- Coastal Modern Palette -->
            <!-- Backgrounds & Surfaces -->
            <Color x:Key="SoftestFrost">#F7FAFB</Color>
            <Color x:Key="PureWhite">#FFFFFF</Color>
            <Color x:Key="IceBlue">#E6F0F2</Color>
            <Color x:Key="DeeperIce">#D9E8EB</Color>
            
            <!-- Primary Typography & Borders -->
            <Color x:Key="DeepestSlate">#1A2B36</Color>
            <Color x:Key="SlateGray">#314757</Color>
            <Color x:Key="MutedSlate">#668091</Color>
            <Color x:Key="SlateTint">#CBDDE5</Color>
            
            <!-- Primary Accents -->
            <Color x:Key="SoftCerulean">#75ABD3</Color>
            <Color x:Key="DeepCerulean">#5A94BE</Color>
            <Color x:Key="CeruleanTint">#EAF4FB</Color>
            
            <!-- Semantic Colors -->
            <Color x:Key="DeepMint">#98C4B5</Color>
            <Color x:Key="PaleMint">#CDE2DB</Color>
            <Color x:Key="SoftPeach">#D8B4A0</Color>
            <Color x:Key="BlushPink">#FCE9EE</Color>
            <Color x:Key="DeepPeach">#C49B85</Color>
            <Color x:Key="PeachTint">#F2E5DD</Color>
            
            <!-- Categorization -->
            <Color x:Key="Lavender">#9E97C9</Color>
            <Color x:Key="PaleLavender">#E8E5F2</Color>
            <Color x:Key="SageGreen">#B6C99B</Color>

            <Color x:Key="Transparent">Transparent</Color>
            
            <!-- Semantic Mappings -->
            <Color x:Key="AppBackground">#F7FAFB</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="TextPrimary">#1A2B36</Color>
            <Color x:Key="TextSecondary">#314757</Color>
            <Color x:Key="TextMuted">#668091</Color>
            <Color x:Key="BorderColor">#CBDDE5</Color>
            
            <Color x:Key="PrimaryAccent">#75ABD3</Color>
            <Color x:Key="SuccessColor">#98C4B5</Color>
            <Color x:Key="WarningColor">#D8B4A0</Color>
            <Color x:Key="DangerColor">#C49B85</Color>
            
            <!-- Global Component Styles -->
            <Style TargetType="Frame">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="HasShadow" Value="False" />
            </Style>
            
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryAccent}" />
                <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="48" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
